@using System.Text.Json
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@rendermode InteractiveServer

<strong>Mozo: @UserName</strong>

@code {
    private string UserName = "Mozo";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var token = await LocalStorage.GetItemAsync<string>("token");
        var userName = GetUserNameFromToken(token);

        if (!string.IsNullOrWhiteSpace(userName))
        {
            UserName = userName;
            StateHasChanged();
        }
    }

    private static string? GetUserNameFromToken(string? token)
    {
        if (string.IsNullOrWhiteSpace(token))
            return null;

        var parts = token.Split('.');
        if (parts.Length < 2)
            return null;

        try
        {
            var payloadBytes = Convert.FromBase64String(PadBase64(parts[1].Replace('-', '+').Replace('_', '/')));
            using var payload = JsonDocument.Parse(payloadBytes);

            foreach (var claim in payload.RootElement.EnumerateObject())
            {
                if (!IsUserNameClaim(claim.Name) || claim.Value.ValueKind != JsonValueKind.String)
                    continue;

                var value = claim.Value.GetString();
                if (!string.IsNullOrWhiteSpace(value))
                    return FormatUserName(value);
            }
        }
        catch
        {
            return null;
        }

        return null;
    }

    private static bool IsUserNameClaim(string claimName)
    {
        var normalized = claimName.Trim().ToLowerInvariant();
        return normalized is "name" or "unique_name" or "preferred_username" or "username" or "user_name" or "user"
            || normalized.EndsWith("/name", StringComparison.OrdinalIgnoreCase)
            || normalized.EndsWith("/givenname", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatUserName(string value)
    {
        var userName = value.Trim();
        var atIndex = userName.IndexOf('@');
        return atIndex > 0 ? userName[..atIndex] : userName;
    }

    private static string PadBase64(string value)
        => value.PadRight(value.Length + (4 - value.Length % 4) % 4, '=');
}
