@page "/StockSection"
@layout AdminLayout
@rendermode InteractiveServer
@implements IDisposable
@using El_buen_sabor.Components.Layout
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Service
@inject StockService _stockService

<PageTitle>Stock - FastRestaurant</PageTitle>

<div class="stock-container">
    <div class="stock-toolbar">
        <div class="stock-title">
            <h2>Stock</h2>
            <p>Ingredientes y cantidades disponibles.</p>
        </div>

        <button type="button" class="add-stock-btn" @onclick="OpenCreateForm">
            + AGREGAR INGREDIENTE
        </button>
    </div>

    <section class="stock-control-panel">
        <div class="search-field">
            <label>Buscar ingredientes</label>
            <input type="text"
                   class="form-control"
                   placeholder="Nombre del ingrediente..."
                   value="@searchText"
                   @oninput="OnSearchChanged" />
        </div>

        <div class="stock-summary">
            <span class="summary-item active">
                Total (@totalItems)
            </span>
        </div>
    </section>

    <div class="table-container">
        @if (isLoading)
        {
            <div class="loading-text">Cargando ingredientes...</div>
        }
        else if (ingredients is null || !ingredients.Any())
        {
            <div class="empty-state">No hay ingredientes para esta búsqueda.</div>
        }
        else
        {
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Ingrediente</th>
                        <th>Stock actual</th>
                        <th>Unidad</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in PagedIngredients)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>

                            <td>
                                <span class="stock-badge @GetStockClass(item.StockCount)">
                                    @FormatStock(item)
                                </span>
                            </td>

                            <td>@GetUnitLabel(item.UnitType)</td>

                            <td>
                                <div class="row-actions">
                                    <button type="button" class="action-btn edit" @onclick="() => OpenEditIngredientModal(item)">
                                        Editar datos
                                    </button>

                                    <button type="button" class="action-btn stock" @onclick="() => OpenEditStockModal(item)">
                                        Cambiar stock
                                    </button>

                                    <button type="button" class="action-btn delete" @onclick="() => OpenDeleteModal(item)">
                                        Eliminar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (ingredients is not null && totalItems > 0 && totalPages > 1)
    {
        <div class="pagination-bar">
            <button type="button" class="pagination-btn" @onclick="PreviousPage" disabled="@(!CanGoPrevious || isLoading)">Anterior</button>
            <span class="pagination-info">
                Mostrando @FirstVisibleItem-@LastVisibleItem de @totalItems ingrediente@(totalItems == 1 ? string.Empty : "s")
                <small>Página @currentPage de @totalPages</small>
            </span>
            <button type="button" class="pagination-btn" @onclick="NextPage" disabled="@(!CanGoNext || isLoading)">Siguiente</button>
        </div>
    }
</div>

@if (showCreateForm)
{
    <div class="modal-overlay">
        <div class="modal-box stock-create-modal">
            <span class="modal-eyebrow">Nuevo ingrediente</span>
            <h3>Agregar ingrediente</h3>
            <p>Cargá el nombre, cómo se mide y el stock inicial.</p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <EditForm Model="@newIngredient" OnValidSubmit="CreateIngredient">
                <div class="modal-form-grid">
                    <div class="form-field full-width">
                        <label>Nombre</label>
                        <InputText class="form-control" @bind-Value="newIngredient.Name" placeholder="Ej: Harina" />
                    </div>

                    <div class="form-field">
                        <label>Se mide en</label>
                        <InputSelect class="form-select" @bind-Value="newIngredient.UnitType">
                            <option value="0">Unidades</option>
                            <option value="1">Gramos</option>
                        </InputSelect>
                    </div>

                    <div class="form-field">
                        <label>Stock inicial</label>
                        <InputNumber class="form-control" @bind-Value="newIngredient.InitialStock" min="0" step="any" />
                        <small>@GetCreateStockHelp(newIngredient.UnitType)</small>
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="button" class="modal-cancel" @onclick="CloseCreateForm" disabled="@isSubmitting">
                        Cancelar
                    </button>

                    <button type="submit" class="modal-confirm" disabled="@isSubmitting">
                        @(isSubmitting ? "Guardando..." : "Guardar ingrediente")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showEditIngredientModal && selectedIngredient is not null)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <span class="modal-eyebrow">Editar datos</span>
            <h3>@selectedIngredient.Name</h3>
            <p>Cambia el nombre o la unidad de manejo del ingrediente.</p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <div class="modal-form-grid">
                <div class="form-field">
                    <label>Nombre</label>
                    <input class="form-control" @bind="updateIngredient.Name" />
                </div>

                <div class="form-field">
                    <label>Unidad</label>
                    <select class="form-select" @bind="updateIngredient.UnitType">
                        <option value="0">Unidades</option>
                        <option value="1">Gramos</option>
                    </select>
                    <small>@GetUnitHelp(updateIngredient.UnitType)</small>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals">
                    Cancelar
                </button>

                <button type="button" class="modal-confirm" @onclick="UpdateIngredient" disabled="@isUpdating">
                    @(isUpdating ? "Guardando..." : "Guardar cambios")
                </button>
            </div>
        </div>
    </div>
}

@if (showEditStockModal && selectedIngredient is not null)
{
    <div class="modal-overlay">
        <div class="modal-box stock-change-modal">
            <span class="modal-eyebrow">Cambiar stock</span>
            <h3>@selectedIngredient.Name</h3>
            <p class="stock-current">Stock actual: <strong>@FormatStock(selectedIngredient)</strong></p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <div class="stock-mode-group" aria-label="Tipo de cambio de stock">
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeAdd ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeAdd)">Agregar</button>
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeRemove ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeRemove)">Quitar</button>
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeReplace ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeReplace)">Reemplazar total</button>
            </div>

            <div class="modal-form-grid">
                <div class="form-field full-width">
                    <label>@GetStockInputLabel() (@GetUnitInputLabel(selectedIngredient.UnitType))</label>
                    <input type="number" class="form-control" @bind="stockChangeAmount" min="0" step="any" />
                    <small>@GetStockModeHelp()</small>
                </div>
            </div>

            <div class="stock-preview">
                Resultado: <strong>@FormatStock(selectedIngredient)</strong> <span>→</span> <strong>@FormatStockPreview()</strong>
            </div>

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals">
                    Cancelar
                </button>

                <button type="button" class="modal-confirm" @onclick="UpdateStock" disabled="@isUpdating">
                    @(isUpdating ? "Guardando..." : "Guardar cambio")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && selectedIngredient is not null)
{
    <div class="modal-overlay">
        <div class="modal-box modal-delete">
            <span class="modal-eyebrow">Confirmar borrado</span>
            <h3>Eliminar @selectedIngredient.Name</h3>
            <p>Esta acción eliminará el ingrediente seleccionado.</p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update error">
                    @modalMessage
                </div>
            }

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals">
                    Cancelar
                </button>

                <button type="button" class="modal-confirm danger" @onclick="DeleteIngredient" disabled="@isDeleting">
                    @(isDeleting ? "Eliminando..." : "Eliminar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const int PageSize = 10;
    private const int UnitTypeUnit = 0;
    private const int UnitTypeGram = 1;
    private const string StockChangeAdd = "add";
    private const string StockChangeRemove = "remove";
    private const string StockChangeReplace = "replace";
    private List<IngredientDTO>? ingredients;

    private CreateIngredientDto newIngredient = new();
    private UpdateIngredientDto updateIngredient = new();

    private IngredientDTO? selectedIngredient;

    private string searchText = string.Empty;
    private string modalMessage = string.Empty;

    private bool isModalError;
    private bool isSubmitting;
    private bool isUpdating;
    private bool isDeleting;
    private bool isLoading;

    private bool showCreateForm;
    private bool showEditIngredientModal;
    private bool showEditStockModal;
    private bool showDeleteModal;

    private decimal stockChangeAmount;
    private string stockChangeMode = StockChangeAdd;
    private int currentPage = 1;
    private int totalItems;
    private int totalPages = 1;
    private CancellationTokenSource? searchDebounceCts;

    private IEnumerable<IngredientDTO> PagedIngredients => ingredients ?? [];
    private int FirstVisibleItem => totalItems == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int LastVisibleItem => Math.Min(currentPage * PageSize, totalItems);
    private bool CanGoPrevious => currentPage > 1;
    private bool CanGoNext => currentPage < totalPages;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadIngredients();
        StateHasChanged();
    }

    private async Task LoadIngredients()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        var page = await _stockService.GetIngredientsAsync(currentPage, PageSize, searchText);
        ingredients = page.Items;
        currentPage = page.Page < 1 ? 1 : page.Page;
        totalItems = page.TotalItems;
        totalPages = Math.Max(1, page.TotalPages);
        EnsureValidPage();
        isLoading = false;
    }

    private void OpenCreateForm()
    {
        newIngredient = new CreateIngredientDto { UnitType = UnitTypeGram };
        modalMessage = string.Empty;
        isModalError = false;
        showCreateForm = true;
    }

    private void CloseCreateForm()
    {
        showCreateForm = false;
        newIngredient = new CreateIngredientDto();
    }

    private async Task CreateIngredient()
    {
        isSubmitting = true;
        modalMessage = string.Empty;
        isModalError = false;

        var validationMessage = ValidateIngredient(newIngredient.Name, newIngredient.InitialStock, newIngredient.UnitType);
        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            isModalError = true;
            modalMessage = validationMessage;
            isSubmitting = false;
            return;
        }

        var result = await _stockService.CreateIngredientAsync(newIngredient);

        if (result)
        {
            showCreateForm = false;
            newIngredient = new CreateIngredientDto();
            currentPage = 1;
            await LoadIngredients();
        }
        else
        {
            isModalError = true;
            modalMessage = "No se pudo crear el ingrediente.";
        }

        isSubmitting = false;
    }

    private void OpenEditIngredientModal(IngredientDTO ingredient)
    {
        selectedIngredient = ingredient;
        updateIngredient = new UpdateIngredientDto
        {
            Name = ingredient.Name,
            UnitType = ingredient.UnitType,
            RowVersion = ingredient.RowVersion
        };

        modalMessage = string.Empty;
        isModalError = false;
        showEditIngredientModal = true;
    }

    private void OpenEditStockModal(IngredientDTO ingredient)
    {
        selectedIngredient = ingredient;
        stockChangeMode = StockChangeAdd;
        stockChangeAmount = 0;

        modalMessage = string.Empty;
        isModalError = false;
        showEditStockModal = true;
    }

    private void OpenDeleteModal(IngredientDTO ingredient)
    {
        selectedIngredient = ingredient;
        modalMessage = string.Empty;
        isModalError = false;
        showDeleteModal = true;
    }

    private void CloseModals()
    {
        showEditIngredientModal = false;
        showEditStockModal = false;
        showDeleteModal = false;
        selectedIngredient = null;
        modalMessage = string.Empty;
        isModalError = false;
    }

    private async Task UpdateIngredient()
    {
        if (selectedIngredient is null)
            return;

        isUpdating = true;
        modalMessage = string.Empty;

        var validationMessage = ValidateIngredientName(updateIngredient.Name);
        if (string.IsNullOrWhiteSpace(validationMessage) && updateIngredient.UnitType == UnitTypeUnit && selectedIngredient.StockCount != Math.Truncate(selectedIngredient.StockCount))
        {
            validationMessage = "No se puede cambiar a unidades si el stock actual tiene decimales.";
        }

        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            isModalError = true;
            modalMessage = validationMessage;
            isUpdating = false;
            return;
        }

        var result = await _stockService.UpdateIngredientAsync(selectedIngredient.Id, updateIngredient);

        if (result)
        {
            isUpdating = false;
            CloseModals();
            await LoadIngredients();
        }
        else
        {
            isModalError = true;
            modalMessage = "No se pudo modificar el ingrediente.";
        }

        isUpdating = false;
    }

    private async Task UpdateStock()
    {
        if (selectedIngredient is null)
            return;

        isUpdating = true;
        modalMessage = string.Empty;

        var newStock = CalculateStockResult(selectedIngredient, stockChangeMode, stockChangeAmount);
        var validationMessage = ValidateStockChange(selectedIngredient, stockChangeMode, stockChangeAmount, newStock);
        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            isModalError = true;
            modalMessage = validationMessage;
            isUpdating = false;
            return;
        }

        var result = await _stockService.UpdateStockAsync(
            selectedIngredient.Id,
            selectedIngredient,
            newStock
        );

        if (result)
        {
            isUpdating = false;
            CloseModals();
            await LoadIngredients();
        }
        else
        {
            isModalError = true;
            modalMessage = "No se pudo modificar el stock.";
        }

        isUpdating = false;
    }

    private async Task DeleteIngredient()
    {
        if (selectedIngredient is null)
            return;

        isDeleting = true;
        modalMessage = string.Empty;

        var result = await _stockService.DeleteIngredientWithResultAsync(selectedIngredient.Id);

        if (result.Success)
        {
            isDeleting = false;
            CloseModals();
            await LoadIngredients();
        }
        else
        {
            isModalError = true;
            modalMessage = result.Message;
        }

        isDeleting = false;
    }

    private void SetStockChangeMode(string mode)
    {
        stockChangeMode = mode;
        stockChangeAmount = mode == StockChangeReplace && selectedIngredient is not null ? selectedIngredient.StockCount : 0;
        modalMessage = string.Empty;
        isModalError = false;
    }

    private async Task PreviousPage()
    {
        if (!CanGoPrevious)
            return;

        currentPage--;
        await LoadIngredients();
    }

    private async Task NextPage()
    {
        if (!CanGoNext)
            return;

        currentPage++;
        await LoadIngredients();
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        searchText = args.Value?.ToString() ?? string.Empty;
        currentPage = 1;

        searchDebounceCts?.Cancel();
        searchDebounceCts?.Dispose();

        var cts = new CancellationTokenSource();
        searchDebounceCts = cts;

        try
        {
            await Task.Delay(300, cts.Token);
            await LoadIngredients();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void EnsureValidPage()
    {
        if (currentPage > totalPages)
            currentPage = totalPages;

        if (currentPage < 1)
            currentPage = 1;
    }

    private static string ValidateIngredient(string name, decimal stock, int unitType)
    {
        var nameMessage = ValidateIngredientName(name);
        if (!string.IsNullOrWhiteSpace(nameMessage))
            return nameMessage;

        return ValidateStock(stock, unitType);
    }

    private static string ValidateIngredientName(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "Debe ingresar el nombre del ingrediente." : string.Empty;
    }

    private static string ValidateStock(decimal stock, int unitType)
    {
        if (stock < 0)
            return "El stock no puede ser negativo.";

        if (unitType == UnitTypeUnit && stock != Math.Truncate(stock))
            return "Los ingredientes por unidad no admiten cantidades decimales.";

        return string.Empty;
    }

    private static string ValidateStockChange(IngredientDTO ingredient, string mode, decimal amount, decimal result)
    {
        if (amount < 0)
            return "La cantidad no puede ser negativa.";

        if (mode == StockChangeRemove && amount > ingredient.StockCount)
            return "No se puede quitar más stock del disponible.";

        return ValidateStock(result, ingredient.UnitType);
    }

    private static string GetUnitLabel(int unitType)
    {
        return unitType == UnitTypeGram ? "Peso" : "Unidades";
    }

    private static string GetUnitInputLabel(int unitType)
    {
        return unitType == UnitTypeGram ? "gramos" : "unidades";
    }

    private static string GetUnitHelp(int unitType)
    {
        return unitType == UnitTypeGram
            ? "Cargá el stock en gramos. La tabla lo mostrará en kg desde 1000 g."
            : "Usá unidades enteras, por ejemplo 1, 2 o 12.";
    }

    private static string GetCreateStockHelp(int unitType)
    {
        return unitType == UnitTypeGram
            ? "Ingresá la cantidad en gramos."
            : "Ingresá unidades enteras.";
    }

    private string GetStockInputLabel()
    {
        return stockChangeMode switch
        {
            StockChangeAdd => "Cantidad a agregar",
            StockChangeRemove => "Cantidad a quitar",
            _ => "Nuevo stock total"
        };
    }

    private string GetStockModeHelp()
    {
        return stockChangeMode switch
        {
            StockChangeAdd => "Suma esta cantidad al stock actual.",
            StockChangeRemove => "Resta esta cantidad del stock actual.",
            _ => "Reemplaza el stock actual por este valor."
        };
    }

    private string FormatStockPreview()
    {
        if (selectedIngredient is null)
            return string.Empty;

        var preview = new IngredientDTO
        {
            Name = selectedIngredient.Name,
            StockCount = CalculateStockResult(selectedIngredient, stockChangeMode, stockChangeAmount),
            UnitType = selectedIngredient.UnitType
        };

        return FormatStock(preview);
    }

    private static decimal CalculateStockResult(IngredientDTO ingredient, string mode, decimal amount)
    {
        return mode switch
        {
            StockChangeAdd => ingredient.StockCount + amount,
            StockChangeRemove => ingredient.StockCount - amount,
            _ => amount
        };
    }

    private static string FormatStock(IngredientDTO ingredient)
    {
        if (ingredient.UnitType != UnitTypeGram)
            return $"{FormatNumber(ingredient.StockCount)} u.";

        if (Math.Abs(ingredient.StockCount) >= 1000)
            return $"{FormatNumber(ingredient.StockCount / 1000)} kg";

        return $"{FormatNumber(ingredient.StockCount)} g";
    }

    private static string FormatNumber(decimal value)
    {
        return value % 1 == 0 ? value.ToString("0") : value.ToString("0.###");
    }

    public void Dispose()
    {
        searchDebounceCts?.Cancel();
        searchDebounceCts?.Dispose();
    }

    private static string GetStockClass(decimal stock)
    {
        if (stock <= 0)
            return "empty";

        if (stock <= 10)
            return "low";

        return "ok";
    }
}
