@page "/BebidasSection"
@layout AdminLayout
@rendermode InteractiveServer
@implements IDisposable
@using El_buen_sabor.Components.Layout
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Service
@using Microsoft.AspNetCore.Components.Forms
@inject MenuCatalogService _menuService
@inject StockService _stockService

<PageTitle>Bebidas - FastRestaurant</PageTitle>

<div class="drinks-container">
    <div class="drinks-toolbar">
        <div class="drinks-title">
            <h2>Bebidas</h2>
            <p>Catálogo, disponibilidad y stock en unidades.</p>
        </div>

        <button type="button" class="add-drink-btn" @onclick="OpenCreateModal">
            + AGREGAR BEBIDA
        </button>
    </div>

    <section class="drink-control-panel">
        <div class="search-field">
            <label>Buscar bebidas</label>
            <input type="text"
                   class="form-control"
                   placeholder="Nombre, marca o descripción..."
                   value="@searchText"
                   @oninput="OnSearchChanged" />
        </div>

        <div class="filter-field">
            <label>Disponibilidad</label>
            <select class="form-select" value="@availabilityFilter" @onchange="OnAvailabilityChanged">
                <option value="todos">Todas</option>
                <option value="si">Disponibles</option>
                <option value="no">No disponibles</option>
            </select>
        </div>

        <div class="filter-field">
            <label>Orden</label>
            <select class="form-select" value="@sortFilter" @onchange="OnSortChanged">
                <option value="nombre">Nombre</option>
                <option value="precio-asc">Precio: menor a mayor</option>
                <option value="precio-desc">Precio: mayor a menor</option>
            </select>
        </div>

        <div class="drinks-summary">
            <span class="summary-item active">Total (@totalItems)</span>
        </div>
    </section>

    <div class="table-container">
        @if (isLoading)
        {
            <div class="loading-text">Cargando bebidas...</div>
        }
        else if (drinks is null || !drinks.Any())
        {
            <div class="empty-state">No hay bebidas para esta búsqueda.</div>
        }
        else
        {
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Bebida</th>
                        <th>Marca</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var drink in drinks)
                    {
                        <tr @key="drink.Id">
                            <td>
                                <div class="drink-cell">
                                    <div class="drink-thumb">
                                        @if (!string.IsNullOrWhiteSpace(drink.ImageUrl))
                                        {
                                            <img src="@_menuService.BuildImageUrl(drink.ImageUrl)" alt="@drink.Name" />
                                        }
                                        else
                                        {
                                            <span>B</span>
                                        }
                                    </div>
                                    <div>
                                        <strong>@drink.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(drink.Description))
                                        {
                                            <small>@drink.Description</small>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>@(!string.IsNullOrWhiteSpace(drink.Brand) ? drink.Brand : "Sin marca")</td>
                            <td>$@drink.Price.ToString("N0")</td>
                            <td>
                                <span class="stock-badge @GetStockClass(drink.StockCount)">
                                    @FormatUnits(drink.StockCount)
                                </span>
                            </td>
                            <td>
                                <span class="availability-pill @(drink.Available ? "available" : "unavailable")">
                                    @(drink.Available ? "Disponible" : "No disponible")
                                </span>
                            </td>
                            <td>
                                <div class="row-actions">
                                    <button type="button" class="action-btn edit" @onclick="() => OpenEditModal(drink)">Editar datos</button>
                                    <button type="button" class="action-btn stock" @onclick="() => OpenStockModal(drink)">Cambiar stock</button>
                                    <button type="button" class="action-btn delete" @onclick="() => OpenDeleteModal(drink)">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (totalItems > 0 && totalPages > 1)
    {
        <div class="pagination-bar">
            <button type="button" class="pagination-btn" @onclick="PreviousPage" disabled="@(!CanGoPrevious || isLoading)">Anterior</button>
            <span class="pagination-info">
                Mostrando @FirstVisibleItem-@LastVisibleItem de @totalItems bebida@(totalItems == 1 ? string.Empty : "s")
                <small>Página @currentPage de @totalPages</small>
            </span>
            <button type="button" class="pagination-btn" @onclick="NextPage" disabled="@(!CanGoNext || isLoading)">Siguiente</button>
        </div>
    }
</div>

@if (showFormModal)
{
    <div class="modal-overlay">
        <div class="modal-box drink-form-modal">
            <span class="modal-eyebrow">@(isEditMode ? "Editar datos" : "Nueva bebida")</span>
            <h3>@(isEditMode ? formDrink.Name : "Agregar bebida")</h3>
            <p>Cargá los datos de la bebida y su stock inicial.</p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <div class="modal-form-grid">
                <div class="form-field">
                    <label>Nombre</label>
                    <input class="form-control" @bind="formDrink.Name" placeholder="Ej: Coca-Cola 500ml" />
                </div>

                <div class="form-field">
                    <label>Marca</label>
                    <input class="form-control" @bind="formDrink.Brand" placeholder="Ej: Coca-Cola" />
                </div>

                <div class="form-field">
                    <label>Precio</label>
                    <input type="number" class="form-control" @bind="formDrink.Price" min="0" step="0.01" />
                </div>

                <div class="form-field">
                    <label>Disponible</label>
                    <select class="form-select"
                            value="@(formDrink.Available ? "true" : "false")"
                            @onchange="ChangeAvailable">
                        <option value="true">Sí</option>
                        <option value="false">No</option>
                    </select>
                </div>

                @if (!isEditMode)
                {
                    <div class="form-field">
                        <label>Stock inicial</label>
                        <input type="number" class="form-control" @bind="formDrink.InitialStock" min="0" step="1" />
                        <small>Ingresá unidades enteras.</small>
                    </div>
                }

                <div class="form-field">
                    <label>Foto de la bebida</label>
                    <div class="file-picker">
                        <label class="file-picker-btn" for="drink-image-input">Seleccionar imagen</label>
                        <span class="file-picker-name">@GetImageFileName()</span>
                        <InputFile id="drink-image-input"
                                   class="file-input-native"
                                   style="height:1px;opacity:0;overflow:hidden;position:absolute;width:1px;"
                                   OnChange="OnImageSelected"
                                   accept="image/*" />
                    </div>
                </div>

                <div class="form-field full-width">
                    <label>Descripción</label>
                    <textarea class="form-control" @bind="formDrink.Description" placeholder="Descripción breve"></textarea>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals" disabled="@isSubmitting">Cancelar</button>
                <button type="button" class="modal-confirm" @onclick="SaveDrink" disabled="@isSubmitting">
                    @(isSubmitting ? "Guardando..." : "Guardar bebida")
                </button>
            </div>
        </div>
    </div>
}

@if (showStockModal && selectedDrink is not null)
{
    <div class="modal-overlay">
        <div class="modal-box stock-change-modal">
            <span class="modal-eyebrow">Cambiar stock</span>
            <h3>@selectedDrink.Name</h3>
            <p class="stock-current">Stock actual: <strong>@FormatUnits(selectedDrink.StockCount)</strong></p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <div class="stock-mode-group" aria-label="Tipo de cambio de stock">
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeAdd ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeAdd)">Agregar</button>
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeRemove ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeRemove)">Quitar</button>
                <button type="button" class="stock-mode-btn @(stockChangeMode == StockChangeReplace ? "active" : "")" @onclick="() => SetStockChangeMode(StockChangeReplace)">Reemplazar total</button>
            </div>

            <div class="modal-form-grid">
                <div class="form-field full-width">
                    <label>@GetStockInputLabel() (unidades)</label>
                    <input type="number" class="form-control" @bind="stockChangeAmount" min="0" step="1" />
                    <small>@GetStockModeHelp()</small>
                </div>
            </div>

            <div class="stock-preview">
                Resultado: <strong>@FormatUnits(selectedDrink.StockCount)</strong> <span>→</span> <strong>@FormatUnits(CalculatePreviewStock())</strong>
            </div>

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals" disabled="@isUpdating">Cancelar</button>
                <button type="button" class="modal-confirm" @onclick="UpdateDrinkStock" disabled="@isUpdating">
                    @(isUpdating ? "Guardando..." : "Guardar cambio")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && selectedDrink is not null)
{
    <div class="modal-overlay">
        <div class="modal-box modal-delete">
            <span class="modal-eyebrow">Confirmar borrado</span>
            <h3>Eliminar @selectedDrink.Name</h3>
            <p>Esta acción eliminará la bebida y su stock asociado.</p>

            @if (!string.IsNullOrEmpty(modalMessage))
            {
                <div class="alert-info-update @(isModalError ? "error" : "success")">
                    @modalMessage
                </div>
            }

            <div class="modal-actions">
                <button type="button" class="modal-cancel" @onclick="CloseModals" disabled="@isUpdating">Cancelar</button>
                <button type="button" class="modal-confirm danger" @onclick="DeleteDrink" disabled="@isUpdating">
                    @(isUpdating ? "Eliminando..." : "Eliminar bebida")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const string StockChangeAdd = "add";
    private const string StockChangeRemove = "remove";
    private const string StockChangeReplace = "replace";
    private const int PageSize = 10;

    private List<DrinkDto> drinks = new();
    private List<CategoryDto> categories = new();
    private CancellationTokenSource? searchDebounceCts;
    private string searchText = string.Empty;
    private string availabilityFilter = "todos";
    private string sortFilter = "nombre";
    private int currentPage = 1;
    private int totalItems;
    private int totalPages;
    private bool isLoading;
    private bool isSubmitting;
    private bool isUpdating;
    private bool showFormModal;
    private bool showStockModal;
    private bool showDeleteModal;
    private bool isEditMode;
    private Guid editingId;
    private Guid drinksCategoryId;
    private FormDrinkModel formDrink = new();
    private IBrowserFile? selectedImage;

    private DrinkDto? selectedDrink;
    private string modalMessage = string.Empty;
    private bool isModalError;
    private string stockChangeMode = StockChangeAdd;
    private decimal stockChangeAmount;

    private bool CanGoPrevious => currentPage > 1;
    private bool CanGoNext => currentPage < totalPages;
    private int FirstVisibleItem => totalItems == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int LastVisibleItem => Math.Min(currentPage * PageSize, totalItems);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        categories = await _menuService.GetCategoriesAsync();
        drinksCategoryId = categories
            .FirstOrDefault(category => category.Name.Contains("Bebida", StringComparison.OrdinalIgnoreCase))
            ?.Id ?? Guid.Empty;

        await LoadDrinksAsync();
        StateHasChanged();
    }

    private async Task LoadDrinksAsync()
    {
        isLoading = true;
        StateHasChanged();

        var result = await _menuService.GetDrinksPageAsync(currentPage, PageSize, searchText, GetAvailableFilter(), sortFilter);
        var drinkStocks = await _stockService.GetDrinkStocksAsync();
        var stocksByDrink = drinkStocks
            .Where(stock => stock.Id_Drink.HasValue)
            .ToDictionary(stock => stock.Id_Drink!.Value, stock => stock);

        drinks = result.Items;
        foreach (var drink in drinks)
        {
            if (stocksByDrink.TryGetValue(drink.Id, out var stock))
            {
                drink.StockId = stock.Id;
                drink.StockCount = stock.Count;
            }
        }

        totalItems = result.TotalItems;
        totalPages = result.TotalPages;
        currentPage = result.PageNumber > 0 ? result.PageNumber : currentPage;
        isLoading = false;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        searchDebounceCts?.Cancel();
        var cts = new CancellationTokenSource();
        searchDebounceCts = cts;

        try
        {
            await Task.Delay(300, cts.Token);
            currentPage = 1;
            await InvokeAsync(LoadDrinksAsync);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task OnAvailabilityChanged(ChangeEventArgs e)
    {
        availabilityFilter = e.Value?.ToString() ?? "todos";
        currentPage = 1;
        await LoadDrinksAsync();
    }

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        sortFilter = e.Value?.ToString() ?? "nombre";
        currentPage = 1;
        await LoadDrinksAsync();
    }

    private async Task PreviousPage()
    {
        if (!CanGoPrevious)
            return;

        currentPage--;
        await LoadDrinksAsync();
    }

    private async Task NextPage()
    {
        if (!CanGoNext)
            return;

        currentPage++;
        await LoadDrinksAsync();
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        editingId = Guid.Empty;
        formDrink = new FormDrinkModel { Available = true };
        selectedImage = null;
        modalMessage = string.Empty;
        isModalError = false;
        showFormModal = true;
    }

    private void OpenEditModal(DrinkDto drink)
    {
        isEditMode = true;
        editingId = drink.Id;
        formDrink = new FormDrinkModel
        {
            Name = drink.Name,
            Brand = drink.Brand,
            Description = drink.Description,
            Price = drink.Price,
            Available = drink.Available,
            ImageUrl = drink.ImageUrl
        };
        selectedImage = null;
        modalMessage = string.Empty;
        isModalError = false;
        showFormModal = true;
    }

    private void OpenStockModal(DrinkDto drink)
    {
        selectedDrink = drink;
        stockChangeMode = StockChangeAdd;
        stockChangeAmount = 0;
        modalMessage = string.Empty;
        isModalError = false;
        showStockModal = true;
    }

    private void OpenDeleteModal(DrinkDto drink)
    {
        selectedDrink = drink;
        modalMessage = string.Empty;
        isModalError = false;
        showDeleteModal = true;
    }

    private void CloseModals()
    {
        showFormModal = false;
        showStockModal = false;
        showDeleteModal = false;
        selectedDrink = null;
        selectedImage = null;
        modalMessage = string.Empty;
        isModalError = false;
    }

    private void OnImageSelected(InputFileChangeEventArgs e)
    {
        selectedImage = e.File;
    }

    private void ChangeAvailable(ChangeEventArgs e)
    {
        formDrink.Available = e.Value?.ToString() == "true";
    }

    private async Task SaveDrink()
    {
        if (!ValidateDrinkForm())
            return;

        isSubmitting = true;
        modalMessage = string.Empty;

        if (selectedImage is not null)
        {
            var imageUrl = await _menuService.UploadImageAsync(selectedImage);
            if (string.IsNullOrWhiteSpace(imageUrl))
            {
                SetModalError("No se pudo subir la imagen. Revisá la configuración de Cloudinary.");
                isSubmitting = false;
                return;
            }

            formDrink.ImageUrl = imageUrl;
        }

        if (isEditMode)
        {
            var updated = await _menuService.UpdateDrinkAsync(editingId, BuildUpdateDto());
            if (!updated)
            {
                SetModalError("No se pudo actualizar la bebida.");
                isSubmitting = false;
                return;
            }
        }
        else
        {
            var created = await _menuService.CreateDrinkWithResultAsync(BuildCreateDto());
            if (created is null)
            {
                SetModalError("No se pudo crear la bebida.");
                isSubmitting = false;
                return;
            }

            var stockCreated = await _stockService.CreateDrinkStockAsync(created.Id, formDrink.InitialStock);
            if (!stockCreated)
            {
                SetModalError("La bebida se creó, pero no se pudo crear su stock inicial.");
                isSubmitting = false;
                return;
            }
        }

        isSubmitting = false;
        CloseModals();
        await LoadDrinksAsync();
    }

    private async Task UpdateDrinkStock()
    {
        if (selectedDrink is null)
            return;

        if (!IsWholeNumber(stockChangeAmount) || stockChangeAmount < 0)
        {
            SetModalError("El stock de bebidas debe ser un número entero no negativo.");
            return;
        }

        var newStock = CalculatePreviewStock();
        if (newStock < 0)
        {
            SetModalError("No podés quitar más unidades de las disponibles.");
            return;
        }

        isUpdating = true;
        var success = selectedDrink.StockId.HasValue
            ? await _stockService.UpdateDrinkStockAsync(selectedDrink.StockId.Value, newStock)
            : await _stockService.CreateDrinkStockAsync(selectedDrink.Id, newStock);

        if (!success)
        {
            isUpdating = false;
            SetModalError("No se pudo actualizar el stock.");
            return;
        }

        isUpdating = false;
        CloseModals();
        await LoadDrinksAsync();
    }

    private async Task DeleteDrink()
    {
        if (selectedDrink is null)
            return;

        isUpdating = true;

        if (selectedDrink.StockId.HasValue)
        {
            var stockDeleted = await _stockService.DeleteDrinkStockAsync(selectedDrink.StockId.Value);
            if (!stockDeleted)
            {
                isUpdating = false;
                SetModalError("No se pudo eliminar el stock asociado.");
                return;
            }
        }

        var deleted = await _menuService.DeleteDrinkAsync(selectedDrink.Id);
        if (!deleted)
        {
            isUpdating = false;
            SetModalError("No se pudo eliminar la bebida.");
            return;
        }

        isUpdating = false;
        CloseModals();
        await LoadDrinksAsync();
    }

    private bool ValidateDrinkForm()
    {
        if (drinksCategoryId == Guid.Empty)
        {
            SetModalError("No se encontró la categoría Bebidas.");
            return false;
        }

        if (string.IsNullOrWhiteSpace(formDrink.Name))
        {
            SetModalError("El nombre es obligatorio.");
            return false;
        }

        if (formDrink.Price <= 0)
        {
            SetModalError("El precio debe ser mayor a cero.");
            return false;
        }

        if (!isEditMode && (!IsWholeNumber(formDrink.InitialStock) || formDrink.InitialStock < 0))
        {
            SetModalError("El stock inicial debe ser un número entero no negativo.");
            return false;
        }

        if (!isEditMode && selectedImage is null)
        {
            SetModalError("Debés subir una imagen para crear la bebida.");
            return false;
        }

        return true;
    }

    private CreateDrinkDto BuildCreateDto() => new()
    {
        CategoryId = drinksCategoryId,
        Name = formDrink.Name.Trim(),
        Brand = string.IsNullOrWhiteSpace(formDrink.Brand) ? null : formDrink.Brand.Trim(),
        Description = string.IsNullOrWhiteSpace(formDrink.Description) ? null : formDrink.Description.Trim(),
        Price = formDrink.Price,
        Available = formDrink.Available,
        ImageUrl = string.IsNullOrWhiteSpace(formDrink.ImageUrl) ? null : formDrink.ImageUrl.Trim()
    };

    private UpdateDrinkDto BuildUpdateDto() => new()
    {
        CategoryId = drinksCategoryId,
        Name = formDrink.Name.Trim(),
        Brand = string.IsNullOrWhiteSpace(formDrink.Brand) ? null : formDrink.Brand.Trim(),
        Description = string.IsNullOrWhiteSpace(formDrink.Description) ? null : formDrink.Description.Trim(),
        Price = formDrink.Price,
        Available = formDrink.Available,
        ImageUrl = string.IsNullOrWhiteSpace(formDrink.ImageUrl) ? null : formDrink.ImageUrl.Trim()
    };

    private bool? GetAvailableFilter() => availabilityFilter switch
    {
        "si" => true,
        "no" => false,
        _ => null
    };

    private void SetStockChangeMode(string mode)
    {
        stockChangeMode = mode;
        modalMessage = string.Empty;
        isModalError = false;
    }

    private decimal CalculatePreviewStock()
    {
        if (selectedDrink is null)
            return 0;

        return stockChangeMode switch
        {
            StockChangeRemove => selectedDrink.StockCount - stockChangeAmount,
            StockChangeReplace => stockChangeAmount,
            _ => selectedDrink.StockCount + stockChangeAmount
        };
    }

    private string GetStockInputLabel() => stockChangeMode switch
    {
        StockChangeRemove => "Unidades a quitar",
        StockChangeReplace => "Nuevo total",
        _ => "Unidades a agregar"
    };

    private string GetStockModeHelp() => stockChangeMode switch
    {
        StockChangeRemove => "Restá unidades vendidas, rotas o vencidas.",
        StockChangeReplace => "Reemplazá el total actual por el conteo real.",
        _ => "Sumá unidades compradas o repuestas."
    };

    private string GetImageFileName()
    {
        if (selectedImage is not null)
            return selectedImage.Name;

        return isEditMode ? "Imagen actual" : "Ningún archivo seleccionado";
    }

    private static string FormatUnits(decimal value) => $"{value:N0} u.";

    private static string GetStockClass(decimal value) => value switch
    {
        <= 0 => "danger",
        <= 5 => "warning",
        _ => "ok"
    };

    private static bool IsWholeNumber(decimal value) => value == Math.Truncate(value);

    private void SetModalError(string message)
    {
        modalMessage = message;
        isModalError = true;
    }

    public void Dispose()
    {
        searchDebounceCts?.Cancel();
        searchDebounceCts?.Dispose();
    }

    private sealed class FormDrinkModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Brand { get; set; }
        public string? Description { get; set; }
        public decimal Price { get; set; }
        public bool Available { get; set; } = true;
        public string? ImageUrl { get; set; }
        public decimal InitialStock { get; set; }
    }
}
