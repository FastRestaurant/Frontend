@page "/BebidasSection"
@layout AdminLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Service
@using El_buen_sabor.Components.Layout
@inject MenuCatalogService _menuService

<div class="platos-container">
    <div class="platos-header">GESTION DE BEBIDAS</div>

    <div class="platos-toolbar">
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Buscar bebida..." @bind="searchText" @bind:event="oninput" />
            </div>
            <select class="filtro-select" @bind="filtroDisponible">
                <option value="todos">Todos</option>
                <option value="si">Solo disponibles</option>
                <option value="no">Solo no disponibles</option>
            </select>
            <select class="filtro-select" @bind="filtroOrden">
                <option value="nombre">Ordenar por nombre</option>
                <option value="precio-asc">Precio: menor a mayor</option>
                <option value="precio-desc">Precio: mayor a menor</option>
            </select>
        </div>
        <button class="btn-agregar" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg"></i> AGREGAR BEBIDA
        </button>
    </div>

    <div class="platos-table-wrapper">
        @if (bebidas == null)
        {
            <div class="loading-text">Cargando bebidas...</div>
        }
        else if (!FilteredDrinks.Any())
        {
            <div class="loading-text">No se encontraron bebidas que coincidan con la búsqueda.</div>
        }
        else
        {
            <table class="platos-table">
                <thead>
                    <tr>
                        <th>NOMBRE</th>
                        <th>PRECIO</th>
                        <th>DISPONIBLE</th>
                        <th>ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bebida in FilteredDrinks)
                    {
                        <tr>
                            <td>@bebida.Name</td>
                            <td>$@bebida.Price</td>
                            <td>
                                <span class="@(bebida.Available ? "disponible-si" : "disponible-no")">
                                    @(bebida.Available ? "SI" : "NO")
                                </span>
                            </td>
                            <td>
                                <div class="acciones-icons">
                                    <button class="btn-editar" @onclick="() => OpenEditModal(bebida)" title="Editar">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </button>
                                    <button class="btn-eliminar" @onclick="() => OpenDeleteModal(bebida)" title="Eliminar">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showFormModal)
{
    <div class="form-overlay">
        <div class="form-box">
            <div class="form-box-header">
                GESTION DE BEBIDAS — @(isEditMode ? "EDITAR BEBIDA" : "AGREGAR BEBIDA")
            </div>
            <div class="form-box-body">

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert-message @(isError ? "error" : "success")">
                        @statusMessage
                    </div>
                }

                <div class="form-field">
                    <label>Nombre de la bebida</label>
                    <input type="text" @bind="formBebida.Name" placeholder="Ej: Coca-Cola 500ml" />
                </div>
                
                <div class="form-field">
                    <label>Precio</label>
                    <input type="text"
                           value="@formBebida.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           @onchange="(e) => { if (decimal.TryParse(e.Value?.ToString()?.Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var p)) formBebida.Price = p; }" />
                </div>
                <div class="form-field">
                    <label>Disponible</label>
                    <select value="@(formBebida.Available ? "true" : "false")"
                            @onchange="CambiarDisponible">
                        <option value="true">Sí</option>
                        <option value="false">No</option>
                    </select>
                </div>
                <div class="form-field form-field-full">
                    <label>Descripción</label>
                    <textarea @bind="formBebida.Description" placeholder="Descripción de la bebida"></textarea>
                </div>
                <div class="form-field form-field-full">
                    <label>Imagen (URL)</label>
                    <input type="text" @bind="formBebida.ImageUrl" placeholder="https://..." />
                </div>

                <div class="form-box-actions">
                    <button class="btn-cancelar" @onclick="CloseFormModal">Cancelar</button>
                    <button class="btn-guardar" @onclick="GuardarBebida" disabled="@isSubmitting">
                        @(isSubmitting ? "Guardando..." : "Guardar bebida")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h3>¿Eliminar bebida?</h3>
            <div class="modal-actions-delete">
                <button class="btn-no-delete" @onclick="CloseDeleteModal">No</button>
                <button class="btn-yes-delete" @onclick="DeleteDrink">Sí</button>
            </div>
        </div>
    </div>
}

@code {
    private List<DrinkDto>? bebidas;
    private List<CategoryDto> categorias = new();
    private string searchText = string.Empty;
    private string filtroDisponible = "todos";
    private string filtroOrden = "nombre";

    private bool showFormModal = false;
    private bool isEditMode = false;
    private Guid editingId;

    private FormBebidaModel formBebida = new();
    private string categoryIdTexto = string.Empty;

    private string statusMessage = string.Empty;
    private bool isError = false;
    private bool isSubmitting = false;

    private bool showDeleteModal = false;
    private DrinkDto selectedDrink = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            bebidas = await _menuService.GetDrinksAsync();
            categorias = await _menuService.GetCategoriesAsync();

            // Buscar automáticamente la categoría de bebidas
            var categoriaBebida = categorias.FirstOrDefault(c =>
                c.Name.Contains("Bebida", StringComparison.OrdinalIgnoreCase));
            if (categoriaBebida != null)
                categoryIdTexto = categoriaBebida.Id.ToString();

            StateHasChanged();
        }
    }

    private IEnumerable<DrinkDto> FilteredDrinks
    {
        get
        {
            if (bebidas == null) return Enumerable.Empty<DrinkDto>();

            var resultado = bebidas.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
                resultado = resultado.Where(b => b.Name != null && b.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));

            if (filtroDisponible == "si")
                resultado = resultado.Where(b => b.Available);
            else if (filtroDisponible == "no")
                resultado = resultado.Where(b => !b.Available);

            resultado = filtroOrden switch
            {
                "precio-asc" => resultado.OrderBy(b => b.Price),
                "precio-desc" => resultado.OrderByDescending(b => b.Price),
                _ => resultado.OrderBy(b => b.Name)
            };

            return resultado;
        }
    }

    private void CambiarDisponible(ChangeEventArgs e)
    {
        formBebida.Available = e.Value?.ToString() == "true";
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        formBebida = new FormBebidaModel { Available = true };
        // No reseteamos categoryIdTexto, ya tiene la categoría Bebidas asignada
        statusMessage = string.Empty;
        showFormModal = true;
    }

    private void OpenEditModal(DrinkDto bebida)
    {
        isEditMode = true;
        editingId = bebida.Id;
        formBebida = new FormBebidaModel
        {
            Name = bebida.Name,
            Description = bebida.Description ?? string.Empty,
            Price = bebida.Price,
            Available = bebida.Available,
            ImageUrl = bebida.ImageUrl
        };
        categoryIdTexto = bebida.CategoryId.ToString();
        statusMessage = string.Empty;
        showFormModal = true;
    }

    private void CloseFormModal()
    {
        showFormModal = false;
        statusMessage = string.Empty;
    }

    private async Task GuardarBebida()
    {
        isSubmitting = true;
        statusMessage = string.Empty;

        if (!Guid.TryParse(categoryIdTexto, out var categoryId))
        {
            isError = true;
            statusMessage = "Seleccioná una categoría válida.";
            isSubmitting = false;
            return;
        }

        bool exito;

        if (isEditMode)
        {
            var updateDto = new UpdateDrinkDto
            {
                CategoryId = categoryId,
                Name = formBebida.Name,
                Description = formBebida.Description,
                Price = formBebida.Price,
                Available = formBebida.Available,
                ImageUrl = formBebida.ImageUrl
            };
            exito = await _menuService.UpdateDrinkAsync(editingId, updateDto);
        }
        else
        {
            var createDto = new CreateDrinkDto
            {
                CategoryId = categoryId,
                Name = formBebida.Name,
                Description = formBebida.Description,
                Price = formBebida.Price,
                Available = formBebida.Available,
                ImageUrl = formBebida.ImageUrl
            };
            exito = await _menuService.CreateDrinkAsync(createDto);
        }

        if (exito)
        {
            isError = false;
            statusMessage = isEditMode ? "¡Bebida actualizada con éxito!" : "¡Bebida creada con éxito!";
            bebidas = await _menuService.GetDrinksAsync();
            StateHasChanged();
            await Task.Delay(1200);
            showFormModal = false;
            statusMessage = string.Empty;
        }
        else
        {
            isError = true;
            statusMessage = "Hubo un error al guardar la bebida. Verifica los datos.";
        }

        isSubmitting = false;
    }

    private void OpenDeleteModal(DrinkDto bebida)
    {
        selectedDrink = bebida;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
    }

    private async Task DeleteDrink()
    {
        var result = await _menuService.DeleteDrinkAsync(selectedDrink.Id);
        if (result)
        {
            showDeleteModal = false;
            bebidas = await _menuService.GetDrinksAsync();
        }
    }

    public class FormBebidaModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal Price { get; set; }
        public bool Available { get; set; }
        public string? ImageUrl { get; set; }
    }
}