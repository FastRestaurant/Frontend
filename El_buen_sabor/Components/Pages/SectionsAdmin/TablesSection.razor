@page "/TablesSection"
@layout AdminLayout
@rendermode InteractiveServer
@using El_buen_sabor.Components.Layout
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Service
@inject TablesService _tablesService
@inject IJSRuntime JsRuntime

<div class="tables-container">
    <div class="tables-toolbar">
        <div class="tables-title">
            <h2>Gestión de Mesas</h2>
            <p>Administra las mesas disponibles para el restaurante.</p>
        </div>
        <button class="add-table-btn" @onclick="OpenCreateForm">+ AGREGAR MESA</button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert-message @(isError ? "error" : "success")">
            @statusMessage
        </div>
    }

    @if (showForm)
    {
        <section class="table-form-section">
            <h3>@(editingTableId.HasValue ? "Editar Mesa" : "Agregar Mesa")</h3>
            <EditForm Model="@tableForm" OnValidSubmit="SaveTable" FormName="TableForm">
                <div class="table-form-grid">
                    <div class="form-field">
                        <label>Número de mesa</label>
                        <InputText @bind-Value="tableForm.Number" class="form-control" placeholder="Ej: 9" required />
                    </div>
                    <div class="form-field">
                        <label>Cantidad de sillas</label>
                        <InputNumber @bind-Value="tableForm.SeatCount" class="form-control" min="1" required />
                    </div>
                    <div class="form-field">
                        <label>Ubicación</label>
                        <InputSelect @bind-Value="tableForm.Location" class="form-select" required>
                            <option value="">Seleccionar</option>
                            @foreach (var location in locations)
                            {
                                <option value="@location">@location</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="form-field">
                        <label>@(editingTableId.HasValue ? "Estado administrativo" : "Estado inicial")</label>
                        <InputSelect @bind-Value="tableForm.IsEnabled" class="form-select">
                            <option value="true">@(editingTableId.HasValue ? "Habilitada" : "Libre")</option>
                            <option value="false">Deshabilitada</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="button" class="cancel-btn" @onclick="CloseForm">Cancelar</button>
                    <button type="submit" class="save-btn" disabled="@isSubmitting">
                        @(isSubmitting ? "Guardando..." : "Guardar Mesa")
                    </button>
                </div>
            </EditForm>
        </section>
    }

    <div class="status-summary">
        <span class="summary-item"><span class="status-dot libre"></span>Libre (@CountByStatus("Libre"))</span>
        <span class="summary-item"><span class="status-dot ocupada"></span>Ocupada (@CountByStatus("Ocupada"))</span>
        <span class="summary-item"><span class="status-dot esperando"></span>Esperando (@CountByStatus("Esperando"))</span>
        <span class="summary-item"><span class="status-dot deshabilitada"></span>Deshabilitada (@CountByStatus("Deshabilitada"))</span>
    </div>

    @if (tables == null)
    {
        <div class="loading-text">Cargando mesas...</div>
    }
    else if (!tables.Any())
    {
        <div class="empty-state">Todavía no hay mesas registradas.</div>
    }
    else
    {
        <div class="tables-grid">
            @foreach (var table in tables)
            {
                <article class="table-card @GetCardClass(table)">
                    <div class="table-card-header">
                        <h3>MESA @table.Number</h3>
                        <span>@NormalizeLocation(table.Location)</span>
                    </div>
                    <div class="table-status">
                        <span class="status-dot @GetStatusClass(table)"></span>
                        <strong>@GetDisplayStatus(table)</strong>
                    </div>
                    <p>@table.SeatCount silla@(table.SeatCount == 1 ? string.Empty : "s")</p>
                    <div class="table-actions">
                        <button class="action-btn" @onclick="() => OpenEditForm(table)">Editar</button>
                        <button class="action-btn toggle" @onclick="() => ToggleTable(table)" disabled="@isSubmitting">
                            @(table.IsEnabled ? "Deshabilitar" : "Habilitar")
                        </button>
                        <button class="action-btn delete" @onclick="() => DeleteTable(table)" disabled="@isSubmitting">&#128465; Borrar</button>
                    </div>
                </article>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="pagination-bar">
                <button class="pagination-btn" @onclick="PreviousPage" disabled="@(!CanGoPrevious || isSubmitting)">Anterior</button>
                <span class="pagination-info">Página @currentPage de @totalPages - @totalItems mesa@(totalItems == 1 ? string.Empty : "s")</span>
                <button class="pagination-btn" @onclick="NextPage" disabled="@(!CanGoNext || isSubmitting)">Siguiente</button>
            </div>
        }
    }
</div>

@code {
    private const int PageSize = 12;
    private List<TableDto>? tables;
    private TableRequestDto tableForm = new() { Location = "Salón", SeatCount = 4, IsEnabled = true };
    private readonly string[] locations = ["Salón", "Terraza", "Patio", "Barra"];
    private Guid? editingTableId;
    private int currentPage = 1;
    private int totalPages = 0;
    private int totalItems = 0;
    private bool showForm = false;
    private bool isSubmitting = false;
    private bool isError = false;
    private string statusMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTables();
    }

    private async Task LoadTables()
    {
        var response = await _tablesService.GetTablesAsync(currentPage, PageSize);
        if (!response.Items.Any() && response.TotalPages > 0 && currentPage > response.TotalPages)
        {
            currentPage = response.TotalPages;
            await LoadTables();
            return;
        }

        tables = response.Items;
        currentPage = response.Page == 0 ? 1 : response.Page;
        totalPages = response.TotalPages;
        totalItems = response.TotalItems;
    }

    private void OpenCreateForm()
    {
        editingTableId = null;
        tableForm = new TableRequestDto { Location = "Salón", SeatCount = 4, IsEnabled = true };
        showForm = true;
        statusMessage = string.Empty;
    }

    private void OpenEditForm(TableDto table)
    {
        editingTableId = table.Id;
        tableForm = new TableRequestDto
        {
            Number = table.Number,
            SeatCount = table.SeatCount,
            Location = NormalizeLocation(table.Location),
            IsEnabled = table.IsEnabled
        };
        showForm = true;
        statusMessage = string.Empty;
    }

    private void CloseForm()
    {
        showForm = false;
        editingTableId = null;
        tableForm = new TableRequestDto { Location = "Salón", SeatCount = 4, IsEnabled = true };
    }

    private async Task SaveTable()
    {
        isSubmitting = true;
        statusMessage = string.Empty;

        var result = editingTableId.HasValue
            ? await _tablesService.UpdateTableAsync(editingTableId.Value, tableForm)
            : await _tablesService.CreateTableAsync(tableForm);

        if (result.Success)
        {
            isError = false;
            statusMessage = result.Message;
            if (!editingTableId.HasValue)
            {
                currentPage = 1;
            }
            CloseForm();
            await LoadTables();
        }
        else
        {
            isError = true;
            statusMessage = result.Message;
        }

        isSubmitting = false;
    }

    private async Task ToggleTable(TableDto table)
    {
        isSubmitting = true;
        statusMessage = string.Empty;

        var result = await _tablesService.ToggleTableStatusAsync(table.Id, !table.IsEnabled);
        if (result.Success)
        {
            isError = false;
            statusMessage = table.IsEnabled ? "Mesa deshabilitada correctamente." : "Mesa habilitada correctamente.";
            await LoadTables();
        }
        else
        {
            isError = true;
            statusMessage = result.Message;
        }

        isSubmitting = false;
    }

    private async Task DeleteTable(TableDto table)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"¿Seguro que querés eliminar la mesa {table.Number}?");
        if (!confirmed)
            return;

        isSubmitting = true;
        statusMessage = string.Empty;

        var result = await _tablesService.DeleteTableAsync(table.Id);
        if (result.Success)
        {
            isError = false;
            statusMessage = result.Message;
            await LoadTables();
        }
        else
        {
            isError = true;
            statusMessage = result.Message;
        }

        isSubmitting = false;
    }

    private bool CanGoPrevious => currentPage > 1;

    private bool CanGoNext => totalPages > 0 && currentPage < totalPages;

    private async Task PreviousPage()
    {
        if (!CanGoPrevious)
            return;

        currentPage--;
        await LoadTables();
    }

    private async Task NextPage()
    {
        if (!CanGoNext)
            return;

        currentPage++;
        await LoadTables();
    }

    private int CountByStatus(string status)
    {
        return tables?.Count(table => GetDisplayStatus(table).Equals(status, StringComparison.OrdinalIgnoreCase)) ?? 0;
    }

    private static string GetDisplayStatus(TableDto table)
    {
        if (!table.IsEnabled)
            return "Deshabilitada";

        return string.IsNullOrWhiteSpace(table.OperationalStatus) ? "Libre" : table.OperationalStatus;
    }

    private static string NormalizeLocation(string location)
    {
        return location.Trim().Equals("Salon", StringComparison.OrdinalIgnoreCase) ? "Salón" : location;
    }

    private static string GetCardClass(TableDto table) => $"table-{GetStatusClass(table)}";

    private static string GetStatusClass(TableDto table)
    {
        return GetDisplayStatus(table).ToLowerInvariant() switch
        {
            "ocupada" => "ocupada",
            "esperando" => "esperando",
            "deshabilitada" => "deshabilitada",
            _ => "libre"
        };
    }
}
