@using Components.Interface;
@implements IDisposable
@inject IOperationService OperationService


<div class="operations-panel @(Items.Any() ? "is-active" : "is-empty")">



    <button type="button" class="operations-header" aria-expanded="@IsExpanded" @onclick="ToggleExpanded">

        <div>
            <span>Carrito</span>
            <h3>Orden actual</h3>
        </div>

        <div class="accordion-summary">
            @if (Items.Any())
            {
                <span class="panel-summary">@Items.Sum(item => item.Cantidad) productos</span>
            }
            else if (table is not null)
            {
                <span class="panel-summary">@table.Name</span>
            }

            <span class="accordion-toggle" aria-hidden="true">@(IsExpanded ? "-" : "+")</span>
        </div>

    </button>



    @if (IsExpanded)
    {
        <div class="operations-body">

            @if (!Items.Any())
            {
                <div class="empty-order">
                    <strong>Orden vacía</strong>
                    <span>Seleccioná una mesa y tocá productos del menú para agregarlos.</span>
                </div>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <div class="operation-item">


                        <div class="item-name">
                            <strong>@item.Producto.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <small>@item.Notes</small>
                            }
                        </div>

                        <div class="item-quantity">
                            <button type="button" class="qty-btn"
                            @onclick="() => DecreaseQuantity(item.Producto.Id)">
                                -
                            </button>

                            <span class="qty-value">
                                @item.Cantidad
                            </span>

                            <button type="button" class="qty-btn"
                            @onclick="() => IncreaseQuantity(item.Producto.Id)">
                                +
                            </button>
                        </div>


                        <div class="item-price">
                            @MoneyFormatter.Format(item.Subtotal)
                        </div>


                        <div class="item-actions">

                            <button type="button" class="icon-btn notes-btn-item"
                            @onclick="() => AddNote(item)">
                                Nota
                            </button>

                            <button type="button" class="icon-btn delete-btn"
                            @onclick="() => RemoveItem(item.Producto.Id)">
                                ×
                            </button>

                        </div>

                    </div>
                }
            }

        </div>

        <div class="operations-footer">

            @if (isSending)
            {
                <div class="operation-feedback pending">
                    Enviando orden...
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(feedbackMessage) && !operationSucceeded)
            {
                <div class="operation-feedback @(operationSucceeded ? "success" : "error")">
                    @feedbackMessage
                </div>
            }

            <div class="total">
                <span>Total</span>
                <strong>@MoneyFormatter.Format(Total)</strong>
            </div>

            <div class="actions">

                <button type="button" class="confirm-btn"
                disabled="@(!CanConfirm)"
                @onclick="ConfirmOrder">
                    @(isSending ? "Enviando..." : "Confirmar")
                </button>

                <button type="button" class="cancel-btn"
                disabled="@(isSending || !Items.Any())"
                @onclick="ConfirmClean">
                    Limpiar
                </button>

            </div>

        </div>
    }

</div>

@if (showNoteModal) // modal para notas 
{
    <div class="modal-backdrop">
        <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="note-modal-title">

            <h4 id="note-modal-title">Notas</h4>

            <p>@selectedItem?.Producto.Name</p>

            <textarea aria-label="Nota del producto" @bind="noteText"
            placeholder="Ej: sin mayonesa">
            </textarea>

            <div class="modal-actions">
                <button type="button" class="modal-btn-save" @onclick="SaveNote">Guardar</button>
                <button type="button" class="modal-btn-cancel" @onclick="CloseNote">Cancelar</button>
            </div>

        </div>
    </div>
}

@if (showConfirmModal) // modal para confirmar orden o limpiar orden
{
    <div class="modal-backdrop">

        <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">

            <h4 id="confirm-modal-title">@tituloMessage</h4>

            <p>@confirmMessage</p>

            <div class="modal-actions">

                <button type="button" class="btn-cancel"
                disabled="@isSending"
                @onclick="CancelConfirm">
                    Cancelar
                </button>

                <button type="button" class="btn-save"
                disabled="@isSending"
                @onclick="ExecuteConfirm">
                    @(isSending ? "Enviando..." : "Confirmar")
                </button>

            </div>

        </div>

    </div>
}


@code {

    [Parameter]
    public List<OrderFromTable> Items { get; set; } = [];

    [Parameter]
    public bool IsExpanded { get; set; } = true;

    [Parameter]
    public EventCallback OnToggle { get; set; }

    private bool showNoteModal = false;

    public Table? table { get; set; }

    private string noteText = "";

    private OrderFromTable? selectedItem;

    private bool showConfirmModal = false;
    private string confirmMessage = "";
    private Func<Task>? confirmAction;
    private string tituloMessage = "";
    private string? feedbackMessage;
    private bool operationSucceeded;
    private bool isSending;


    private decimal Total =>
        Items.Sum(x => x.Subtotal);

    private bool CanConfirm => !isSending && table is not null && Items.Any();


    protected override void OnInitialized()
    {
        Items = OperationService.GetItems();
        table = OperationService.GetTable();
        OperationService.OnChange += Refresh;
    }

    private void Refresh()
    {
        Items = OperationService.GetItems();
        table = OperationService.GetTable();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        OperationService.OnChange -= Refresh;
    }

    private async Task ToggleExpanded()
    {
        if (OnToggle.HasDelegate)
            await OnToggle.InvokeAsync();
    }

    private void RemoveItem(Guid productId)
    {
        OperationService.RemoveProduct(productId);
    }

    private void CancelOrder()
    {
        OperationService.Clear();
    }

    private void IncreaseQuantity(Guid productId)
    {
        OperationService.IncreaseQuantity(productId);
    }

    private void DecreaseQuantity(Guid productId)
    {
        OperationService.DecreaseQuantity(productId);
    }

    private void AddNote(OrderFromTable item)
    {
        selectedItem = item;
        noteText = item.Notes ?? "";
        showNoteModal = true;
    }

    private void SaveNote()
    {
        if (selectedItem is null)
            return;

        OperationService.AddNote(selectedItem.Producto.Id, noteText);

        showNoteModal = false;
        selectedItem = null;
        noteText = "";
    }

    private void CloseNote()
    {
        showNoteModal = false;
        selectedItem = null;
        noteText = "";
    }


    private void ConfirmClean()
    {
        Confirm("¿Seguro que querés limpiar la orden?", "Limpiar orden", () =>
        {
            CancelOrder();
            feedbackMessage = null;
            return Task.CompletedTask;
        });
    }

    private void ConfirmOrder()
    {
        Confirm("¿Seguro que querés confirmar la orden?", "Confirmar orden", ExecuteOrder);
    }

    private void CancelConfirm()
    {
        if (isSending)
            return;

        showConfirmModal = false;
        confirmAction = null;
        confirmMessage = "";
        tituloMessage = "";
    }




    private void Confirm(string message,string titulo, Func<Task> onConfirm)  // guardo la acción que se ejecuta al confirmar
    {
        confirmMessage = message;  // guarda el mensaje a mostrar en el modal
        confirmAction = onConfirm; // guarda la accion en la variable 
        showConfirmModal = true; // abre el modal 
        tituloMessage = titulo;
    }


    private async Task ExecuteConfirm()  // se ejecuta al confirmar en el modal
    {
        if (isSending)
            return;

        var action = confirmAction;

        showConfirmModal = false; // cierro el modal
        confirmAction = null; // vacio la accion
        confirmMessage = ""; // vacio el mensaje
        tituloMessage = "";

        await InvokeAsync(StateHasChanged);

        if (action is not null)
            await action.Invoke();
    }

    private async Task ExecuteOrder()
    {
        isSending = true;
        feedbackMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await OperationService.SendOrderAsync();
            operationSucceeded = result.Success;
            feedbackMessage = result.Success ? null : result.Message;
        }
        catch
        {
            operationSucceeded = false;
            feedbackMessage = "No se pudo enviar la orden. Intentá nuevamente.";
        }
        finally
        {
            isSending = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
