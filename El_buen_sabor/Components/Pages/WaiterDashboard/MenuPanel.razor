@using Components.Interface
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Shared
@implements IDisposable
@inject IOperationService OperationService
@inject ITableService TableService
@inject MenuService MenuService

<div class="menu-panel-container">

    <div class="menu-header">
        <div>
            <h3>Menú</h3>
        </div>

        @if (isCheckingTableStatus)
        {
            <span class="menu-header-status">Verificando mesa</span>
        }
    </div>

    @if (isCheckingTableStatus)
    {
        <div class="menu-status-line" role="status">
            <strong>Verificando estado de la mesa</strong>
            <span>Revisando si todavía se pueden agregar productos.</span>
        </div>
    }
    else if (isAccountRequested)
    {
        <div class="menu-status-line account-requested" role="status">
            <strong>Cuenta solicitada</strong>
            <span>Menú bloqueado hasta liberar la mesa.</span>
        </div>
    }
    else
    {
        <div class="menu-panel-category-bar">
            @if (isLoadingCategories)
            {
                <p>Cargando...</p>
            }
            else if (!Categories.Any())
            {
                <p>No hay categorías disponibles</p>
            }
            else
            {
                @foreach (var cat in Categories)
                {
                    <button type="button"
                            class="category-btn @(SelectedCategoryId == cat.Id ? "active" : "")"
                            aria-pressed="@(SelectedCategoryId == cat.Id)"
                            @onclick="() => SelectCategory(cat.Id)">
                        @cat.Name
                    </button>
                }
            }
        </div>

        <div class="menu-panel-products-grid">
            @if (isLoadingProducts)
            {
                <div class="menu-status-line inline" role="status">
                    <strong>Cargando productos</strong>
                    <span>Preparando el menú de esta categoría.</span>
                </div>
            }
            else if (SelectedCategoryId is null)
            {
                <div class="menu-status-line inline" role="status">
                    <strong>Seleccioná una categoría</strong>
                    <span>Elegí una sección para ver productos.</span>
                </div>
            }
            else if (!Products.Any())
            {
                <div class="menu-status-line inline" role="status">
                    <strong>Sin productos disponibles</strong>
                    <span>Probá con otra categoría.</span>
                </div>
            }
            else
            {
                @foreach (var product in Products)
                {
                    <article class="menu-panel-product-card @ProductCardClass(product)">
                        @if (string.IsNullOrWhiteSpace(product.Url))
                        {
                            <div class="product-image product-placeholder">
                                <span>@ProductInitial(product)</span>
                            </div>
                        }
                        else
                        {
                            <div class="product-image">
                                <img src="@product.Url" alt="@product.Name" />
                            </div>
                        }

                        <div class="product-info">
                            <span class="product-type">@ProductTypeLabel(product)</span>
                            <h4>@product.Name</h4>
                            <p class="price">@product.Price.ToString("C")</p>
                        </div>

                        <button type="button"
                                class="add-btn"
                                @onclick="() => AddToOrder(product)">
                            Agregar
                        </button>
                    </article>
                }
            }
        </div>

        @if (SelectedCategoryId is not null)
        {
            <Pagination CurrentPage="currentPage"
                        TotalPages="totalPages"
                        HasPreviousPage="hasPreviousPage"
                        HasNextPage="hasNextPage"
                        OnPreviousPage="PreviousPage"
                        OnNextPage="NextPage"
                        OnGoToPage="GoToPage" />
        }
    }
</div>

@code {
    public List<Category> Categories = [];
    public Guid? SelectedCategoryId;
    public List<Product> Products = [];

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalItems = 0;
    private bool hasPreviousPage;
    private bool hasNextPage;

    private bool isLoadingCategories;
    private bool isLoadingProducts;
    private bool isAccountRequested;
    private bool isCheckingTableStatus;

    protected override async Task OnInitializedAsync()
    {
        OperationService.OnChange += Refresh;

        isLoadingCategories = true;
        Categories = await MenuService.GetCategories();
        isLoadingCategories = false;

        await RefreshTableStatusAsync();

        if (!isAccountRequested && Categories.Any())
            await SelectCategory(Categories[0].Id);
    }

    private async Task SelectCategory(Guid id)
    {
        if (isAccountRequested)
            return;

        SelectedCategoryId = id;
        currentPage = 1;

        await LoadProducts(id);
    }

    private async Task LoadProducts(Guid categoryId)
    {
        if (isAccountRequested)
            return;

        isLoadingProducts = true;

        try
        {
            var result = await MenuService.GetProductsByCategory(categoryId, currentPage, pageSize);

            Products = result.Items;
            currentPage = result.PageNumber;
            pageSize = result.PageSize;
            totalItems = result.TotalItems;
            totalPages = result.TotalPages;
            hasPreviousPage = result.HasPreviousPage;
            hasNextPage = result.HasNextPage;
        }
        finally
        {
            isLoadingProducts = false;
        }
    }

    private async Task PreviousPage()
    {
        if (!hasPreviousPage || SelectedCategoryId is null || isLoadingProducts)
            return;

        currentPage--;
        await LoadProducts(SelectedCategoryId.Value);
    }

    private async Task NextPage()
    {
        if (!hasNextPage || SelectedCategoryId is null || isLoadingProducts)
            return;

        currentPage++;
        await LoadProducts(SelectedCategoryId.Value);
    }

    private async Task GoToPage(int page)
    {
        if (page == currentPage || SelectedCategoryId is null || isLoadingProducts)
            return;

        currentPage = page;
        await LoadProducts(SelectedCategoryId.Value);
    }

    private async Task AddToOrder(Product product)
    {
        if (isAccountRequested)
            return;

        var table = OperationService.GetTable();

        if (table is not null)
        {
            var orders = await TableService.GetOrdersByTableAsync(table.Id);
            var activeOrder = orders.FirstOrDefault(order =>
                order.Status is not OrderStatuses.Closed and not OrderStatuses.Cancelled);

            if (activeOrder?.Status == OrderStatuses.ReadyToClose)
            {
                isAccountRequested = true;
                return;
            }
        }

        OperationService.AddProduct(product);
    }

    private async void Refresh()
    {
        await RefreshTableStatusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshTableStatusAsync()
    {
        var table = OperationService.GetTable();
        isAccountRequested = false;

        if (table is null)
        {
            isCheckingTableStatus = false;
            return;
        }

        isCheckingTableStatus = true;

        try
        {
            var orders = await TableService.GetOrdersByTableAsync(table.Id);
            var activeOrder = orders.FirstOrDefault(order =>
                order.Status is not OrderStatuses.Closed and not OrderStatuses.Cancelled);

            isAccountRequested = activeOrder?.Status == OrderStatuses.ReadyToClose;
        }
        finally
        {
            isCheckingTableStatus = false;
        }
    }

    public void Dispose()
    {
        OperationService.OnChange -= Refresh;
    }

    private static string ProductTypeLabel(Product product)
        => product.ProductType == ProductTypes.Drink ? "Bebida" : "Plato";

    private static string ProductCardClass(Product product)
        => product.ProductType == ProductTypes.Drink ? "drink-card" : "dish-card";

    private static string ProductInitial(Product product)
        => string.IsNullOrWhiteSpace(product.Name)
            ? "?"
            : product.Name.Trim()[0].ToString().ToUpperInvariant();
}