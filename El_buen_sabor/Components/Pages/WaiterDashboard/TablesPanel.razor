@using Components.Interface
@implements IDisposable
@inject ITableService TableService
@inject IOperationService OperationService
@inject El_buen_sabor.Components.Service.AuthSessionService AuthSession
@inject El_buen_sabor.Components.Service.OrderRealtimeService OrderRealtime

<div class="tables-panel @(SelectorMode ? "selector-mode" : "")">
    <div class="tables-header">
        <div>
            <h3>@(SelectorMode ? "Seleccioná una mesa" : "Mesas")</h3>
        </div>
        @if (!SelectorMode && !isLoading && Tables.Count > 0)
        {
            <strong>@Tables.Count</strong>
        }
    </div>

    @if (SelectorMode && !isLoading && Tables.Count > 0)
    {
        <div class="table-filters" role="group" aria-label="Filtro de mesas">
            <button type="button" class="table-filter @(IsFilterSelected(TableFilter.MyTables) ? "active" : "")" aria-pressed="@IsFilterSelected(TableFilter.MyTables)" @onclick="() => SetFilter(TableFilter.MyTables)">
                Mis mesas <span>@MyTablesCount</span>
            </button>
            <button type="button" class="table-filter @(IsFilterSelected(TableFilter.InService) ? "active" : "")" aria-pressed="@IsFilterSelected(TableFilter.InService)" @onclick="() => SetFilter(TableFilter.InService)">
                En servicio <span>@InServiceCount</span>
            </button>
            <button type="button" class="table-filter @(IsFilterSelected(TableFilter.ToDeliver) ? "active" : "")" aria-pressed="@IsFilterSelected(TableFilter.ToDeliver)" @onclick="() => SetFilter(TableFilter.ToDeliver)">
                Para entregar <span>@ToDeliverCount</span>
            </button>
            <button type="button" class="table-filter @(IsFilterSelected(TableFilter.Free) ? "active" : "")" aria-pressed="@IsFilterSelected(TableFilter.Free)" @onclick="() => SetFilter(TableFilter.Free)">
                Libres <span>@FreeCount</span>
            </button>
            <button type="button" class="table-filter @(IsFilterSelected(TableFilter.Occupied) ? "active" : "")" aria-pressed="@IsFilterSelected(TableFilter.Occupied)" @onclick="() => SetFilter(TableFilter.Occupied)">
                Ocupadas <span>@OccupiedCount</span>
            </button>
        </div>

        <div class="table-status-legend" aria-label="Leyenda de estados de mesa">
            <span class="legend-item"><i class="legend-dot free" aria-hidden="true"></i>Libre</span>
            <span class="legend-item"><i class="legend-dot occupied" aria-hidden="true"></i>Ocupada</span>
            <span class="legend-item"><i class="legend-dot waiting" aria-hidden="true"></i>Cuenta solicitada</span>
            <span class="legend-item"><i class="legend-dot disabled" aria-hidden="true"></i>Deshabilitada</span>
            <span class="legend-item"><i class="legend-dot ready-overdue" aria-hidden="true"></i>Para entregar</span>
        </div>
    }

    @if (isLoading)
    {
        <div class="panel-state">Cargando mesas...</div>
    }
    else if (Tables.Count == 0)
    {
        <div class="empty-state">
            <strong>No hay mesas disponibles</strong>
            <span>Las mesas creadas en el sistema aparecerán aquí.</span>
        </div>
    }
    else
    {
        <nav class="location-tabs" aria-label="Sectores del restaurante">
            @foreach (var location in Locations)
            {
                <button type="button" class="table-card @TableClass(table) @(IsSelected(table) ? "selected" : "")"
                    aria-pressed="@IsSelected(table)"
                    disabled="@(!table.IsEnabled)"
                    title="@($"{table.Name} - {TableStatusLabel(table)}")"
                    @onclick="() => SelectTable(table)">

                    <span class="table-figure" aria-hidden="true">
                        <svg class="table-icon" viewBox="0 0 35 35" focusable="false">
                            <rect class="table-icon-surface" x="7.015" y="11.913" width="20.97" height="11.174" rx="0.8" />
                            <g class="table-icon-line">
                                <line x1="7.015" y1="11.913" x2="27.985" y2="11.913" />
                                <line x1="7.015" y1="23.087" x2="7.015" y2="11.913" />
                                <line x1="27.985" y1="23.087" x2="7.015" y2="23.087" />
                                <line x1="27.985" y1="11.913" x2="27.985" y2="23.087" />

                                @if (ShowTopCenterSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(4.88 -1.1)">
                                        <line x1="10.419" y1="9.34" x2="9.187" y2="6.943" />
                                        <path d="M16.058,6.943c0,0-1.023-1.193-3.436-1.193s-3.436,1.193-3.436,1.193" />
                                        <line x1="14.826" y1="9.34" x2="16.058" y2="6.943" />
                                        <path d="M15.568,11.913l-0.144-2.102c0-0.26-0.212-0.472-0.472-0.472h-4.659c-0.26,0-0.472,0.212-0.472,0.472l-0.144,2.102" />
                                    </g>
                                }

                                @if (ShowBottomCenterSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(4.88 1.1)">
                                        <line x1="14.826" y1="25.66" x2="16.058" y2="28.057" />
                                        <path d="M9.187,28.057c0,0,1.023,1.193,3.436,1.193s3.436-1.193,3.436-1.193" />
                                        <line x1="10.419" y1="25.66" x2="9.187" y2="28.057" />
                                        <path d="M9.677,23.087l0.144,2.102c0,0.26,0.212,0.472,0.472,0.472h4.659c0.26,0,0.472-0.212,0.472-0.472l0.144-2.102" />
                                    </g>
                                }

                                @if (ShowTopLeftSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(0 -1.1)">
                                        <line x1="10.419" y1="9.34" x2="9.187" y2="6.943" />
                                        <path d="M16.058,6.943c0,0-1.023-1.193-3.436-1.193s-3.436,1.193-3.436,1.193" />
                                        <line x1="14.826" y1="9.34" x2="16.058" y2="6.943" />
                                        <path d="M15.568,11.913l-0.144-2.102c0-0.26-0.212-0.472-0.472-0.472h-4.659c-0.26,0-0.472,0.212-0.472,0.472l-0.144,2.102" />
                                    </g>
                                }

                                @if (ShowTopRightSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(0 -1.1)">
                                        <line x1="20.174" y1="9.34" x2="18.942" y2="6.943" />
                                        <path d="M25.813,6.943c0,0-1.023-1.193-3.436-1.193s-3.436,1.193-3.436,1.193" />
                                        <line x1="24.581" y1="9.34" x2="25.813" y2="6.943" />
                                        <path d="M25.323,11.913l-0.144-2.102c0-0.26-0.212-0.472-0.472-0.472h-4.659c-0.26,0-0.472,0.212-0.472,0.472l-0.144,2.102" />
                                    </g>
                                }

                                @if (ShowBottomRightSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(0 1.1)">
                                        <line x1="24.581" y1="25.66" x2="25.813" y2="28.057" />
                                        <path d="M18.942,28.057c0,0,1.023,1.193,3.436,1.193s3.436-1.193,3.436-1.193" />
                                        <line x1="20.174" y1="25.66" x2="18.942" y2="28.057" />
                                        <path d="M19.432,23.087l0.144,2.102c0,0.26,0.212,0.472,0.472,0.472h4.659c0.26,0,0.472-0.212,0.472-0.472l0.144-2.102" />
                                    </g>
                                }

                                @if (ShowBottomLeftSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(0 1.1)">
                                        <line x1="14.826" y1="25.66" x2="16.058" y2="28.057" />
                                        <path d="M9.187,28.057c0,0,1.023,1.193,3.436,1.193s3.436-1.193,3.436-1.193" />
                                        <line x1="10.419" y1="25.66" x2="9.187" y2="28.057" />
                                        <path d="M9.677,23.087l0.144,2.102c0,0.26,0.212,0.472,0.472,0.472h4.659c0.26,0,0.472-0.212,0.472-0.472l0.144-2.102" />
                                    </g>
                                }

                                @if (ShowRightSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(0.9 0)">
                                        <line x1="30.559" y1="15.297" x2="32.955" y2="14.064" />
                                        <path d="M32.955,20.936c0,0,1.193-1.023,1.193-3.436s-1.193-3.436-1.193-3.436" />
                                        <line x1="30.559" y1="19.703" x2="32.955" y2="20.936" />
                                        <path d="M27.985,20.446l2.102-0.144c0.26,0,0.472-0.212,0.472-0.472v-4.659c0-0.26-0.212-0.472-0.472-0.472l-2.102-0.144" />
                                    </g>
                                }

                                @if (ShowLeftSeat(table.SeatCount))
                                {
                                    <g class="table-icon-chair" transform="translate(-0.9 0)">
                                        <line x1="4.442" y1="19.703" x2="2.045" y2="20.936" />
                                        <path d="M2.045,14.064c0,0-1.193,1.023-1.193,3.436s1.193,3.436,1.193,3.436" />
                                        <line x1="4.442" y1="15.297" x2="2.045" y2="14.064" />
                                        <path d="M7.015,14.554l-2.102,0.144c-0.26,0-0.472,0.212-0.472,0.472v4.659c0,0.26,0.212,0.472,0.472,0.472l2.102,0.144" />
                                    </g>
                                }
                            </g>
                        </svg>
                    </span>

                    <span class="table-copy">
                        <span class="table-number" title="@table.Name">@table.Name</span>
                        <span class="table-status">@TableStatusLabel(table)</span>
                    </span>

                </button>
            }
            <button type="button" class="refresh-button" title="Actualizar mesas" @onclick="LoadTables">
                <span aria-hidden="true">↻</span> Actualizar
            </button>
            <button type="button"
                    class="edit-layout-button @(layoutEditMode ? "active" : "")"
                    aria-pressed="@layoutEditMode"
                    @onclick="ToggleLayoutEditMode">
                @(layoutEditMode ? "✓ Terminar edición" : "✥ Mover mesas")
            </button>
            @if (layoutEditMode)
            {
                <button type="button" class="reset-layout-button" @onclick="ResetLayout">
                    Restaurar orden
                </button>
            }
        </nav>

        <div class="floor-shell">
            <div class="floor-heading">
                <div>
                    <span>Plano del restaurante</span>
                    <h3>@LocationLabel(selectedLocation)</h3>
                </div>
                <div class="table-status-legend" aria-label="Estados de las mesas">
                    <span><i class="free"></i>Libre</span>
                    <span><i class="occupied"></i>Ocupada</span>
                    <span><i class="waiting"></i>Cuenta solicitada</span>
                    <span><i class="disabled"></i>Deshabilitada</span>
                </div>
            </div>

            @if (!VisibleTables.Any())
            {
                <div class="empty-state floor-empty">
                    <strong>No hay mesas en este sector</strong>
                </div>
            }
            else
            {
                <div class="restaurant-floor @FloorClass(selectedLocation)">
                    @if (IsLocation("Patio"))
                    {
                        <div class="garden-scenery" aria-hidden="true">
                            <div class="garden-border garden-border-top"></div>
                            <div class="garden-border garden-border-bottom"></div>
                            <div class="fountain">
                                <i class="water-jet"></i>
                                <span>FUENTE</span>
                            </div>
                        </div>
                    }
                    else if (IsLocation("Terraza"))
                    {
                        <div class="satellite-street" aria-hidden="true">
                            <div class="street">
                                <span></span><span></span><span></span>
                            </div>
                            <div class="sidewalk">
                                <i></i><i></i><i></i>
                            </div>
                        </div>
                        <div class="map-staircase terrace-staircase" aria-hidden="true">
                            <strong>ESCALERA</strong>
                            <div class="steps">
                                <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
                            </div>
                            <span>↓ BARRA</span>
                        </div>
                    }
                    else if (IsLocation("Barra"))
                    {
                        <aside class="map-feature bar-feature" aria-hidden="true">
                            <div class="bar-counter">
                                <i></i><i></i><i></i><i></i>
                            </div>
                            <div class="feature-label">BARRA</div>
                        </aside>
                        <div class="map-staircase bar-staircase" aria-hidden="true">
                            <strong>SUBE A TERRAZA</strong>
                            <div class="steps">
                                <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
                            </div>
                            <span>↑</span>
                        </div>
                    }
                    else
                    {
                        <aside class="map-feature service-area" aria-hidden="true">
                            <div class="counter">
                                <span></span><span></span><span></span>
                            </div>
                            <div class="feature-label kitchen-label">COCINA</div>
                        </aside>
                    }

                    <div class="tables-layout @(layoutEditMode ? "layout-editing" : "")"
                         data-location="@selectedLocation">
                        @{
                            var tableIndex = 0;
                        }
                        @foreach (var table in VisibleTables)
                        {
                            <div @key="table.Id"
                                 class="table-place @TableSizeClass(table)"
                                 data-table-id="@table.Id"
                                 data-index="@tableIndex"
                                 data-position-x="@PositionValue(table.PositionX)"
                                 data-position-y="@PositionValue(table.PositionY)"
                                 data-editable="@layoutEditMode.ToString().ToLowerInvariant()">
                                <div class="chairs top" aria-hidden="true">
                                    @for (var i = 0; i < TopChairCount(table); i++)
                                    {
                                        <i></i>
                                    }
                                </div>
                                <div class="chairs side left" aria-hidden="true">
                                    @for (var i = 0; i < LeftChairCount(table); i++)
                                    {
                                        <i></i>
                                    }
                                </div>

                                <button type="button"
                                        class="table-card @TableClass(table) @(IsSelected(table) ? "selected" : "")"
                                        aria-pressed="@IsSelected(table)"
                                        disabled="@(!table.IsEnabled)"
                                        title="@($"{table.Name} · {table.SeatCount} sillas · {TableStatusLabel(table.OperationalStatus)}")"
                                        @onclick="() => SelectTable(table)">
                                    <strong>@DisplayNumber(table)</strong>
                                    <span>@TableStatusLabel(table.OperationalStatus)</span>
                                    <small>@table.SeatCount sillas</small>
                                </button>

                                <div class="chairs side right" aria-hidden="true">
                                    @for (var i = 0; i < RightChairCount(table); i++)
                                    {
                                        <i></i>
                                    }
                                </div>
                                <div class="chairs bottom" aria-hidden="true">
                                    @for (var i = 0; i < BottomChairCount(table); i++)
                                    {
                                        <i></i>
                                    }
                                </div>
                            </div>
                            tableIndex++;
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public bool SelectorMode { get; set; }

    private readonly CancellationTokenSource refreshCancellation = new();
    private DotNetObjectReference<TablesPanel>? componentReference;
    private List<Table> Tables = [];
    private bool isLoading = true;
    private int currentPage = 1;
    private const int PageSize = 15;
    private Guid? currentUserId;
    private TableFilter selectedFilter = TableFilter.MyTables;

    private List<Table> VisibleTables => (selectedFilter switch
    {
        TableFilter.MyTables => currentUserId.HasValue
            ? Tables.Where(table => table.ActiveWaiterId == currentUserId.Value)
            : [],
        TableFilter.InService => Tables.Where(table => table.IsEnabled),
        TableFilter.Free => Tables.Where(table => table.OperationalStatus == TableStatuses.Free),
        TableFilter.Occupied => Tables.Where(table => table.OperationalStatus == TableStatuses.Occupied),
        TableFilter.ToDeliver => Tables.Where(MesaListaVisible),
        _ => Tables
    }).ToList();

    private IEnumerable<Table> PagedTables => SelectorMode
        ? VisibleTables.Skip((currentPage - 1) * PageSize).Take(PageSize)
        : VisibleTables;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(VisibleTables.Count / (double)PageSize));
    private int VisibleTablesCount => VisibleTables.Count;
    private int FirstVisibleItem => VisibleTablesCount == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int LastVisibleItem => Math.Min(currentPage * PageSize, VisibleTablesCount);

    private int InServiceCount => Tables.Count(table => table.IsEnabled);
    private int MyTablesCount => currentUserId.HasValue ? Tables.Count(table => table.ActiveWaiterId == currentUserId.Value) : 0;
    private int FreeCount => Tables.Count(table => table.OperationalStatus == TableStatuses.Free);
    private int OccupiedCount => Tables.Count(table => table.OperationalStatus == TableStatuses.Occupied);
    private int ToDeliverCount => Tables.Count(MesaListaVisible);

    protected override void OnInitialized()
    {
        OperationService.OnChange += Refresh;
        OrderRealtime.DeliveryItemsChanged += RefreshDeliveryState;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && Tables.Count > 0)
        {
            componentReference ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("tableLayout.initialize", componentReference);
        }
    }

    private async Task LoadTables()
    {
        var loadedTables = await TableService.GetTablesAsync();
        Tables = loadedTables;
        isLoading = false;

        if (string.IsNullOrWhiteSpace(selectedLocation) || !Locations.Contains(selectedLocation))
            selectedLocation = Locations.FirstOrDefault() ?? string.Empty;
    }

    private async Task RefreshPeriodicallyAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await LoadTables();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void RefreshDeliveryState()
    {
        InvokeAsync(StateHasChanged);
    }

    private bool MesaListaVisible(Table table)
    {
        var nowUtc = DateTime.UtcNow;
        return OrderRealtime.GetReadyDeliveryItems()
            .Where(item => item.TableId == table.Id)
            .Any(item => DeliveryGatingRules.SuperoUmbral(DeliveryGatingRules.AsUtc(item.ReadyAt), nowUtc)
                || (currentUserId.HasValue && item.WaiterId == currentUserId.Value));
    }

    private async Task LoadTables()
    {
        componentReference ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("tableLayout.reset", selectedLocation, componentReference);
        await LoadTables();
    }

    [JSInvokable]
    public async Task SaveTablePosition(string tableId, double positionX, double positionY)
    {
        if (!Guid.TryParse(tableId, out var id))
            return;

        var result = await TableService.UpdateTablePositionAsync(
            id,
            Math.Round((decimal)positionX, 2),
            Math.Round((decimal)positionY, 2));

        if (!result.Success)
            await LoadTables();
    }

    private void SelectTable(Table table)
    {
        if (table.IsEnabled && !layoutEditMode)
            OperationService.SetTable(table);
    }

    private bool IsSelected(Table table) => OperationService.GetTable()?.Id == table.Id;

    // Reparte cualquier cantidad de sillas entre los cuatro lados sin ocultar ninguna.
    private static int TopChairCount(Table table)
        => table.SeatCount == 2 ? 1 : Math.Max(0, (table.SeatCount + 3) / 4);

    private static int RightChairCount(Table table)
        => table.SeatCount == 2 ? 0 : Math.Max(0, (table.SeatCount + 2) / 4);

    private static int BottomChairCount(Table table)
        => table.SeatCount == 2 ? 1 : Math.Max(0, (table.SeatCount + 1) / 4);

    private static int LeftChairCount(Table table)
        => table.SeatCount == 2 ? 0 : Math.Max(0, table.SeatCount / 4);

    private static string TableSizeClass(Table table) => table.SeatCount switch
    {
        >= 16 => "grand",
        >= 10 => "banquet",
        >= 6 => "wide",
        _ => "compact"
    };

    private bool IsLocation(string location)
        => selectedLocation.Equals(location, StringComparison.OrdinalIgnoreCase);

    private static string FloorClass(string location) => location.ToLowerInvariant() switch
    {
        "patio" => "floor-patio open-plan",
        "terraza" => "floor-terrace open-plan",
        "barra" => "floor-bar",
        _ => "floor-main"
    };

    private static string DisplayNumber(Table table)
        => string.IsNullOrWhiteSpace(table.Number) ? table.Name.Replace("Mesa", "").Trim() : table.Number;

    private static string NormalizeLocation(string? location)
    {
        if (string.IsNullOrWhiteSpace(location))
            return "Sin sector";

        return location.Trim().Equals("Salon", StringComparison.OrdinalIgnoreCase) ? "Salón" : location.Trim();
    }

    private static string LocationLabel(string location)
        => location.Equals("Salón", StringComparison.OrdinalIgnoreCase) ? "Salón principal" : location;

    private static int LocationOrder(string location) => location.ToLowerInvariant() switch
    {
        "salón" or "salon" => 0,
        "patio" => 1,
        "terraza" => 2,
        "barra" => 3,
        _ => 4
    };

    private static int ParseTableNumber(string number)
        => int.TryParse(number, out var value) ? value : int.MaxValue;

    private static string PositionValue(decimal? position)
        => position?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;

    private string TableClass(Table table)
    {
        var baseClass = table.OperationalStatus switch
        {
            TableStatuses.Occupied => "occupied",
            TableStatuses.Waiting => "waiting",
            _ => "free"
        };

        return MesaListaVisible(table) ? $"{baseClass} ready-overdue" : baseClass;
    }

    private string TableStatusLabel(Table table)
    {
        if (MesaListaVisible(table))
            return "Para entregar";

        return table.OperationalStatus == TableStatuses.Waiting ? "Cuenta solicitada" : table.OperationalStatus;
    }

    private static int IconSeatCount(int seatCount) => Math.Clamp(seatCount, 2, 6);

    private static bool ShowTopCenterSeat(int seatCount)
        => IconSeatCount(seatCount) is 2 or 3;

    private static bool ShowBottomCenterSeat(int seatCount)
        => IconSeatCount(seatCount) == 2;

    private static bool ShowLeftSeat(int seatCount)
        => IconSeatCount(seatCount) is 3 or 5 or 6;

    private static bool ShowRightSeat(int seatCount)
        => IconSeatCount(seatCount) is 3 or 6;

    private static bool ShowTopLeftSeat(int seatCount)
        => IconSeatCount(seatCount) is 4 or 5 or 6;

    private static bool ShowTopRightSeat(int seatCount)
        => IconSeatCount(seatCount) is 4 or 5 or 6;

    private static bool ShowBottomLeftSeat(int seatCount)
        => IconSeatCount(seatCount) is 4 or 5 or 6;

    private static bool ShowBottomRightSeat(int seatCount)
        => IconSeatCount(seatCount) is 4 or 5 or 6;

    public void Dispose()
    {
        OperationService.OnChange -= Refresh;
        OrderRealtime.DeliveryItemsChanged -= RefreshDeliveryState;
    }

    public void Dispose()
    {
        MyTables,
        InService,
        ToDeliver,
        Free,
        Occupied
    }
}
