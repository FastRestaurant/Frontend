@using Components.Interface
@implements IDisposable

@inject IOperationService OperationService
@inject ITableService TableService
@inject OrderRealtimeService OrderRealtime


<div class="orders-panel">
    <button type="button" class="order-list-header" aria-expanded="@IsExpanded" @onclick="ToggleExpanded">
        <div>
            <span>Mesa</span>
            <h3>Cuenta actual</h3>
        </div>

        <div class="accordion-summary">
            <strong>@OrdersLabel</strong>
            <span class="accordion-toggle" aria-hidden="true">@(IsExpanded ? "-" : "+")</span>
        </div>
    </button>

    @if (IsExpanded)
    {
        @if (isLoading)
        {
            <div class="orders-state">Cargando pedidos...</div>
        }
        else if (OperationService.GetTable() is null)
        {
            <div class="orders-state">Seleccioná una mesa</div>
        }
        else if (TableService.LastOrdersLoadFailed)
        {
            <div class="orders-state">No se pudo cargar la cuenta. Reintentá.</div>
        }
        else if (!CurrentOrders.Any())
        {
            <div class="orders-state">No hay consumo cargado para esta mesa</div>
        }
        else
        {
            @if (ActiveOrder is not null)
            {
                <div class="table-action-panel">
                    @if (CanRequestBill)
                    {
                        <button type="button" class="bill-btn" disabled="@isUpdatingTable" @onclick="ShowBillConfirmation">
                            @(isUpdatingTable ? "Procesando..." : "Pedir cuenta")
                        </button>
                    }
                    else if (CurrentOrders.Any())
                    {
                        <div class="table-action-hint">
                            Entregá todos los platos de todas las órdenes antes de pedir la cuenta.
                        </div>
                    }

                    @if (CanReleaseTable)
                    {
                        <div class="payment-summary">
                            <span>Total a pagar</span>
                            <strong>@MoneyFormatter.Format(TableTotal)</strong>
                        </div>

                        <button type="button" class="release-btn" disabled="@isUpdatingTable" @onclick="ShowReleaseConfirmation">
                            @(isUpdatingTable ? "Procesando..." : "Liberar mesa")
                        </button>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(tableActionMessage) && !tableActionSucceeded)
            {
                <div class="table-action-message @(tableActionSucceeded ? "success" : "error")">
                    @tableActionMessage
                </div>
            }

            <div class="orders-list">
                @foreach (var order in CurrentOrders)
                {
                    <article class="order-card">
                        <div class="order-card-head">
                            <strong>#@ShortId(order.Id)</strong>
                            <span class="order-status-badge @GetOrderStatusClass(order)">@GetOrderStatusLabel(order)</span>
                        </div>

                        @foreach (var item in order.OrderItems)
                        {
                            <div class="order-item-line">
                                <div>
                                    <span>@item.Cantidad x</span>
                                    <strong>@item.Producto.Name</strong>
                                    <small class="item-status @GetItemStatusClass(item.Status)">@GetItemStatusLabel(item.Status)</small>
                                </div>
                                <em>
                                    <span>Subtotal</span>
                                    @MoneyFormatter.Format(item.Subtotal)
                                </em>
                            </div>
                        }

                        <div class="order-total">
                            <span>Total</span>
                            <strong>@MoneyFormatter.Format(order.Total)</strong>
                        </div>

                        @if (HasUnfinishedItems(order))
                        {
                            <div class="order-deliver">
                                <button type="button" class="deliver-table-btn @(SuperoUmbralOf(order) ? "overdue" : "")"
                                        disabled="@(!CanDeliverOrder(order) || deliveringOrderIds.Contains(order.Id))"
                                        @onclick="() => AskDeliverOrderConfirmation(order)">
                                    @DeliverOrderButtonLabel(order)
                                </button>
                                @if (HasCookingItems(order))
                                {
                                    <div class="table-action-hint">
                                        Esperando que la cocina termine todos los platos.
                                    </div>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
    }
</div>

@if (showBillConfirm && ActiveOrder is not null)
{
    <div class="confirm-backdrop">
        <div class="confirm-box" role="dialog" aria-modal="true" aria-labelledby="bill-confirm-title">
            <span>Confirmar cuenta</span>
            <h4 id="bill-confirm-title">Pedir cuenta</h4>
            <p>Se va a marcar la cuenta de @OperationService.GetTable()?.Name como solicitada por <strong>@MoneyFormatter.Format(TableTotal)</strong>.</p>

            <div class="confirm-actions">
                <button type="button" class="confirm-cancel" @onclick="HideBillConfirmation">Cancelar</button>
                <button type="button" class="confirm-release" disabled="@isUpdatingTable" @onclick="ConfirmRequestBill">
                    @(isUpdatingTable ? "Solicitando..." : "Confirmar")
                </button>
            </div>
        </div>
    </div>
}

@if (showReleaseConfirm && ActiveOrder is not null)
{
    <div class="confirm-backdrop">
        <div class="confirm-box" role="dialog" aria-modal="true" aria-labelledby="release-confirm-title">
            <span>Confirmar cierre</span>
            <h4 id="release-confirm-title">Liberar @OperationService.GetTable()?.Name</h4>
            <p>Confirmá que el cliente pagó <strong>@MoneyFormatter.Format(TableTotal)</strong>.</p>

            <div class="confirm-actions">
                <button type="button" class="confirm-cancel" @onclick="HideReleaseConfirmation">Cancelar</button>
                <button type="button" class="confirm-release" disabled="@isUpdatingTable" @onclick="ConfirmReleaseTable">
                    @(isUpdatingTable ? "Liberando..." : "Confirmar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeliverOrderConfirm && orderToConfirm is not null)
{
    <div class="confirm-backdrop">
        <div class="confirm-box" role="dialog" aria-modal="true" aria-labelledby="deliver-order-confirm-title">
            <span>Confirmar entrega</span>
            <h4 id="deliver-order-confirm-title">Entregar orden #@ShortId(orderToConfirm.Id)</h4>
            <p>¿Confirmás que los <strong>@ReadyItemsOf(orderToConfirm).Count</strong> platos de esta orden llegaron a la mesa?</p>

            <div class="confirm-actions">
                <button type="button" class="confirm-cancel" disabled="@IsPendingDeliveryInProgress" @onclick="HideDeliverOrderConfirmation">Cancelar</button>
                <button type="button" class="confirm-release" disabled="@IsPendingDeliveryInProgress" @onclick="ConfirmDeliverOrder">
                    @(IsPendingDeliveryInProgress ? "Entregando..." : "Confirmar entrega")
                </button>
            </div>
        </div>
    </div>
}

@code {

    private List<Order> Orders = [];
    private bool isLoading;
    private bool isUpdatingTable;
    private bool showBillConfirm;
    private bool showReleaseConfirm;
    private string? tableActionMessage;
    private bool tableActionSucceeded;
    private Order? orderToConfirm;
    private bool showDeliverOrderConfirm;
    private readonly HashSet<Guid> deliveringOrderIds = [];

    [Parameter]
    public bool IsExpanded { get; set; } = true;

    [Parameter]
    public EventCallback OnToggle { get; set; }

    private List<Order> CurrentOrders => Orders.Where(IsActiveOrder).ToList();
    private Order? ActiveOrder => CurrentOrders.FirstOrDefault();
    private bool AllTableOrdersDelivered => CurrentOrders.Count > 0
        && CurrentOrders.All(AllItemsDeliveredOrCancelled);
    private bool CanRequestBill => AllTableOrdersDelivered
        && CurrentOrders.Any(order => order.Status is OrderStatuses.Open or OrderStatuses.InProgress);
    private bool CanReleaseTable => CurrentOrders.Count > 0
        && CurrentOrders.All(order => order.Status == OrderStatuses.ReadyToClose)
        && AllTableOrdersDelivered;
    private decimal TableTotal => CurrentOrders.Sum(order => order.Total);
    private string OrdersLabel => CurrentOrders.Count == 1 ? "1 pedido" : $"{CurrentOrders.Count} pedidos";

    private static List<OrderFromTable> ReadyItemsOf(Order order)
        => order.OrderItems.Where(item => item.Status == OrderItemStatuses.Ready).ToList();

    private static bool HasUnfinishedItems(Order order)
        => order.OrderItems.Any(item => item.Status is OrderItemStatuses.Pending
            or OrderItemStatuses.SentToKitchen
            or OrderItemStatuses.Ready);

    private static bool HasCookingItems(Order order)
        => order.OrderItems.Any(item => item.Status is OrderItemStatuses.Pending or OrderItemStatuses.SentToKitchen);

    private static bool IsOrderFullyReady(Order? order)
        => order is not null
        && order.OrderItems.Count > 0
        && order.OrderItems.All(item => item.Status is OrderItemStatuses.Ready or OrderItemStatuses.Delivered or OrderItemStatuses.Cancelled)
        && order.OrderItems.Any(item => item.Status == OrderItemStatuses.Ready);

    private DateTime? MesaListaAtUtcOf(Order? order)
    {
        if (order is null)
            return null;

        var readyAtTimes = order.OrderItems
            .Where(item => item.Status == OrderItemStatuses.Ready && item.ReadyAt.HasValue)
            .Select(item => DeliveryGatingRules.AsUtc(item.ReadyAt!.Value))
            .ToList();

        return readyAtTimes.Count == 0 ? null : readyAtTimes.Max();
    }

    private bool SuperoUmbralOf(Order order)
    {
        var mesaListaAt = MesaListaAtUtcOf(order);
        return mesaListaAt.HasValue && DeliveryGatingRules.SuperoUmbral(mesaListaAt.Value, DateTime.UtcNow);
    }

    private static bool CanDeliverOrder(Order? order)
        => IsOrderFullyReady(order);

    private string DeliverOrderButtonLabel(Order order)
    {
        if (deliveringOrderIds.Contains(order.Id))
            return "Entregando...";

        if (HasCookingItems(order) || ReadyItemsOf(order).Count == 0)
            return "Esperando cocina";

        return $"Entregar orden ({ReadyItemsOf(order).Count})";
    }


    protected override void OnInitialized()
    {
        Refresh();

        OperationService.OnChange += Refresh;
        OrderRealtime.DeliveryItemsChanged += RefreshDeliveryState;
    }


    private async void Refresh()
    {
        var table = OperationService.GetTable();

        tableActionMessage = null;

        if (table != null)
        {
            isLoading = true;
            await InvokeAsync(StateHasChanged);
            Orders = await TableService.GetOrdersByTableAsync(table.Id);
            isLoading = false;
        }
        else
        {
            Orders = [];
            isLoading = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void RefreshDeliveryState()
    {
        InvokeAsync(StateHasChanged);
    }

    private static string ShortId(Guid id)
        => id.ToString("N")[..8];

    private static bool IsActiveOrder(Order order)
        => order.Status is not OrderStatuses.Closed and not OrderStatuses.Cancelled;

    private string GetOrderStatusLabel(Order order)
    {
        if (order.Status == OrderStatuses.ReadyToClose)
            return "Cuenta solicitada";

        if (AllItemsDeliveredOrCancelled(order))
            return "Listo para cuenta";

        if (OrderRealtime.IsDelayed(order.Id))
            return "Demorado";

        if (OrderRealtime.IsReady(order.Id) || IsOrderFullyReady(order))
            return "Listo para entregar";

        return order.Status switch
        {
            OrderStatuses.InProgress => "En cocina",
            OrderStatuses.Open => "Pendiente",
            _ => order.Status
        };
    }

    private string GetOrderStatusClass(Order order)
    {
        if (order.Status == OrderStatuses.ReadyToClose || AllItemsDeliveredOrCancelled(order))
            return "ready";

        if (OrderRealtime.IsDelayed(order.Id))
            return "delayed";

        if (OrderRealtime.IsReady(order.Id) || IsOrderFullyReady(order))
            return "ready";

        return order.Status switch
        {
            OrderStatuses.InProgress => "preparing",
            OrderStatuses.Open => "pending",
            _ => "neutral"
        };
    }

    private static bool AllItemsDeliveredOrCancelled(Order? order)
        => order is not null && order.OrderItems.Count > 0 && order.OrderItems.All(item => item.Status is OrderItemStatuses.Delivered or OrderItemStatuses.Cancelled);

    private static string GetItemStatusLabel(string status) => status switch
    {
        OrderItemStatuses.Pending => "Pendiente",
        OrderItemStatuses.SentToKitchen => "En cocina",
        OrderItemStatuses.Ready => "Para entregar",
        OrderItemStatuses.Delivered => "Entregado",
        OrderItemStatuses.Cancelled => "Cancelado",
        _ => "Sin estado"
    };

    private static string GetItemStatusClass(string status) => status switch
    {
        OrderItemStatuses.Pending => "pending",
        OrderItemStatuses.SentToKitchen => "preparing",
        OrderItemStatuses.Ready => "ready",
        OrderItemStatuses.Delivered => "delivered",
        OrderItemStatuses.Cancelled => "cancelled",
        _ => "neutral"
    };

    private async Task ToggleExpanded()
    {
        if (OnToggle.HasDelegate)
            await OnToggle.InvokeAsync();
    }

    private void ShowBillConfirmation()
    {
        tableActionMessage = null;
        showBillConfirm = true;
    }

    private void HideBillConfirmation()
    {
        if (!isUpdatingTable)
            showBillConfirm = false;
    }

    private async Task ConfirmRequestBill()
    {
        await RunTableAction(OperationService.RequestBillAsync);
        showBillConfirm = false;
    }

    private void ShowReleaseConfirmation()
    {
        tableActionMessage = null;
        showReleaseConfirm = true;
    }

    private void HideReleaseConfirmation()
    {
        if (!isUpdatingTable)
            showReleaseConfirm = false;
    }

    private async Task ConfirmReleaseTable()
    {
        var result = await RunTableAction(OperationService.ReleaseTableAsync);
        showReleaseConfirm = false;

        if (result?.Success == true)
            OperationService.ClearTable();
    }

    private bool IsPendingDeliveryInProgress => orderToConfirm is not null && deliveringOrderIds.Contains(orderToConfirm.Id);

    private void AskDeliverOrderConfirmation(Order order)
    {
        if (!CanDeliverOrder(order) || deliveringOrderIds.Contains(order.Id))
            return;

        tableActionMessage = null;
        orderToConfirm = order;
        showDeliverOrderConfirm = true;
    }

    private void HideDeliverOrderConfirmation()
    {
        if (!IsPendingDeliveryInProgress)
            showDeliverOrderConfirm = false;
    }

    private async Task ConfirmDeliverOrder()
    {
        if (orderToConfirm is null)
            return;

        var orderId = orderToConfirm.Id;
        var itemsToDeliver = ReadyItemsOf(orderToConfirm).Select(item => item.Id).ToList();

        deliveringOrderIds.Add(orderId);
        tableActionMessage = null;
        await InvokeAsync(StateHasChanged);

        var anyFailed = false;

        foreach (var itemId in itemsToDeliver)
        {
            var result = await TableService.MarkOrderItemDeliveredAsync(orderId, itemId);
            if (result.Success)
                OrderRealtime.RemoveReadyDeliveryItem(itemId);
            else
                anyFailed = true;
        }

        deliveringOrderIds.Remove(orderId);
        showDeliverOrderConfirm = false;
        orderToConfirm = null;

        if (anyFailed)
        {
            tableActionSucceeded = false;
            tableActionMessage = "No se pudieron entregar todos los platos. Actualizá e intentá nuevamente.";
        }

        OperationService.NotifyChanged();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<OperationResultDto?> RunTableAction(Func<Task<OperationResultDto>> action)
    {
        isUpdatingTable = true;
        tableActionMessage = null;
        OperationResultDto? result = null;

        try
        {
            result = await action();
            tableActionSucceeded = result.Success;
            tableActionMessage = result.Success ? null : result.Message;
        }
        catch
        {
            tableActionSucceeded = false;
            tableActionMessage = "No se pudo actualizar la mesa. Intentá nuevamente.";
        }
        finally
        {
            isUpdatingTable = false;
        }

        await InvokeAsync(StateHasChanged);
        return result;
    }

    public void Dispose()
    {
        OperationService.OnChange -= Refresh;
        OrderRealtime.DeliveryItemsChanged -= RefreshDeliveryState;
    }

}
