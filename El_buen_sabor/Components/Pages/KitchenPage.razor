@page "/kitchen"
@rendermode InteractiveServer
@using System.Globalization
@using El_buen_sabor.Components.Layout
@using El_buen_sabor.Components.Service
@using Microsoft.JSInterop
@implements IDisposable
@layout KitchenLayout
@inject NavigationManager Navigation
@inject KitchenService KitchenService
@inject KitchenRealtimeService KitchenRealtime
@inject IJSRuntime JSRuntime

<PageTitle>Cocina - FastRestaurant</PageTitle>

<section class="kds-screen">
    <header class="kds-topbar">
        <div class="brand-block">
            <strong>FastRestaurant</strong>
        </div>

        <nav class="kds-tabs" aria-label="Vista de cocina">
            <button type="button" class="@TabClass(KitchenTab.Now)" aria-pressed="@(_activeTab == KitchenTab.Now)" @onclick="() => SetActiveTab(KitchenTab.Now)">
                Cocinar ahora
                <span>@NowItems.Count()</span>
            </button>
            <button type="button" class="@TabClass(KitchenTab.Upcoming)" aria-pressed="@(_activeTab == KitchenTab.Upcoming)" @onclick="() => SetActiveTab(KitchenTab.Upcoming)">
                Próximamente
                <span>@UpcomingItems.Count()</span>
            </button>
        </nav>

        <div class="clock-block">
            <div class="clock-time">
                <span>@SpanishDay</span>
                <strong>@_nowLocal.ToString("HH:mm")</strong>
            </div>
            <a href="/" class="logout-kds-button" onclick="localStorage.removeItem('token'); localStorage.removeItem('refreshToken'); location.replace('/'); return false;">Cerrar sesión</a>
        </div>
    </header>

    <main class="ticket-board">
        <div class="board-toolbar">
            <div class="board-status">
                <strong>@(isLoading ? "Cargando..." : $"{ActiveItems.Count} platos")</strong>
                <span>@(string.IsNullOrWhiteSpace(errorMessage) ? $"Página {_currentPage} de {TotalPages}" : errorMessage)</span>
            </div>
            <div class="urgency-legend" aria-label="Referencias de tiempo">
                <span><i class="legend-dot urgent"></i>Faltan 0-5 min</span>
                <span><i class="legend-dot warning"></i>Faltan 6-15 min</span>
                <span><i class="legend-dot normal"></i>Faltan +15 min</span>
                <span><i class="legend-dot upcoming"></i>Por empezar</span>
            </div>
            <div class="page-controls">
                <button type="button" @onclick="PreviousPage" disabled="@(_currentPage == 1)">Anterior</button>
                <button type="button" @onclick="NextPage" disabled="@(_currentPage == TotalPages)">Siguiente</button>
            </div>
        </div>

        <div class="ticket-table">
            <div class="table-head">
                <span>@TimeColumnTitle</span>
                <span>Orden</span>
                <span>Cant.</span>
                <span>Plato</span>
                <span>Nota</span>
                <span>Hora lista</span>
                <span>Acción</span>
            </div>

            @foreach (var item in PagedItems)
            {
                <article class="@RowClass(item)">
                    <div class="time-cell">
                        <strong>@PrimaryTimeLabel(item)</strong>
                        <small>@SecondaryTimeLabel(item)</small>
                    </div>
                    <div class="order-cell">
                        <span>#@item.OrderNumber</span>
                        <small>Mesa @item.TableNumber</small>
                    </div>
                    <div class="quantity-cell">@item.Quantity</div>
                    <div class="dish-cell">
                        @if (IsNew(item.ItemId))
                        {
                            <span class="new-badge">Nuevo</span>
                        }
                        @item.Name
                    </div>
                    <div class="note-cell">@item.NoteDisplay</div>
                    <div class="ready-cell">@ReadyAtLabel(item)</div>
                    <div class="action-cell">
                        <button type="button" class="done-button" disabled="@(!CanConfirm(item))" @onclick="() => AskFinishConfirmation(item)">
                            @ActionLabel(item)
                        </button>
                    </div>
                </article>
            }

            @foreach (var _ in Enumerable.Range(0, EmptyRows))
            {
                <article class="ticket-row empty-row" aria-hidden="true">
                    <div class="time-cell"></div>
                    <div class="order-cell"></div>
                    <div class="quantity-cell"></div>
                    <div class="dish-cell"></div>
                    <div class="note-cell"></div>
                    <div class="ready-cell"></div>
                    <div class="action-cell"></div>
                </article>
            }
        </div>
    </main>
</section>

@if (_itemToConfirm is not null)
{
    <div class="kds-confirm-backdrop">
        <div class="kds-confirm-box" role="dialog" aria-modal="true" aria-labelledby="kds-confirm-title">
            <span>Confirmar plato listo</span>
            <h3 id="kds-confirm-title">@_itemToConfirm.Name</h3>
            <p>¿Confirmás que este plato está listo para entregar?</p>
            <small>Pedido <strong>#@_itemToConfirm.OrderNumber</strong></small>

            <div class="kds-confirm-actions">
                <button type="button" class="kds-confirm-cancel" disabled="@isCompleting" @onclick="CancelFinishConfirmation">Cancelar</button>
                <button type="button" class="kds-confirm-ready" disabled="@isCompleting" @onclick="ConfirmFinished">
                    @(isCompleting ? "Confirmando..." : "Listo")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const int PageSize = 15;
    private static readonly TimeSpan ClockTickInterval = TimeSpan.FromSeconds(5);

    private KitchenTab _activeTab = KitchenTab.Now;
    private int _currentPage = 1;
    private DateTime _nowUtc;
    private DateTime _nowLocal;
    private TimeSpan _browserClockOffset = TimeSpan.Zero;
    private TimeSpan _browserLocalOffset = TimeSpan.Zero;
    private PeriodicTimer? _clockTimer;
    private CancellationTokenSource? _clockTimerCancellation;
    private List<KitchenQueueItemDto> cookingItems = [];
    private List<KitchenQueueItemDto> waitingItems = [];
    private HashSet<Guid>? _knownItemIds;
    private readonly Dictionary<Guid, DateTime> _newItemSince = [];
    private static readonly TimeSpan NewItemTagDuration = TimeSpan.FromSeconds(20);
    private static readonly TimeSpan SoundThrottle = TimeSpan.FromSeconds(10);
    private DateTime? _lastSoundPlayedAt;
    private KitchenItemView? _itemToConfirm;
    private bool isLoading;
    private bool isCompleting;
    private string? errorMessage;

    private IEnumerable<KitchenItemView> AllItems => cookingItems
        .Concat(waitingItems)
        .Select(ToKitchenItemView);

    private IEnumerable<KitchenItemView> NowItems => AllItems
        .Where(item => item.StartAtUtc <= _nowUtc)
        .OrderBy(item => item.ReadyAtUtc)
        .ThenBy(item => item.StartAtUtc);

    private IEnumerable<KitchenItemView> UpcomingItems => AllItems
        .Where(item => item.StartAtUtc > _nowUtc)
        .OrderBy(item => item.StartAtUtc)
        .ThenBy(item => item.ReadyAtUtc);

    private IReadOnlyList<KitchenItemView> ActiveItems => (_activeTab == KitchenTab.Now ? NowItems : UpcomingItems).ToArray();
    private IReadOnlyList<KitchenItemView> PagedItems => ActiveItems
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToArray();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(ActiveItems.Count / (double)PageSize));
    private int EmptyRows => Math.Max(0, PageSize - PagedItems.Count);
    private string SpanishDay => CultureInfo.GetCultureInfo("es-AR").TextInfo.ToTitleCase(_nowLocal.ToString("dddd", CultureInfo.GetCultureInfo("es-AR")));
    private string TimeColumnTitle => _activeTab == KitchenTab.Upcoming ? "Empieza en" : "Restante";

    protected override async Task OnInitializedAsync()
    {
        UpdateClock();
        KitchenRealtime.QueueChanged += HandleQueueChanged;
        KitchenRealtime.Reconnected += LoadQueueAsync;
        await LoadQueueAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SynchronizeBrowserClockAsync();
            StartClock();
            await KitchenRealtime.StartAsync();
            StateHasChanged();
        }
    }

    private async Task SynchronizeBrowserClockAsync()
    {
        try
        {
            var browserNowIso = await JSRuntime.InvokeAsync<string>("fastRestaurantClock.nowIso");
            var timezoneOffsetMinutes = await JSRuntime.InvokeAsync<int>("fastRestaurantClock.timezoneOffsetMinutes");

            if (DateTimeOffset.TryParse(browserNowIso, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal, out var browserNow))
                _browserClockOffset = browserNow.UtcDateTime - DateTime.UtcNow;

            _browserLocalOffset = TimeSpan.FromMinutes(-timezoneOffsetMinutes);
        }
        catch
        {
            _browserClockOffset = TimeSpan.Zero;
            _browserLocalOffset = DateTime.Now - DateTime.UtcNow;
        }

        UpdateClock();
        ClampCurrentPage();
    }

    private void StartClock()
    {
        _clockTimerCancellation = new CancellationTokenSource();
        _clockTimer = new PeriodicTimer(ClockTickInterval);
        _ = RunClockAsync(_clockTimerCancellation.Token);
    }

    private async Task RunClockAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_clockTimer is not null && await _clockTimer.WaitForNextTickAsync(cancellationToken))
            {
                UpdateClock();
                ExpireNewItemTags();
                ClampCurrentPage();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void UpdateClock()
    {
        _nowUtc = DateTime.UtcNow.Add(_browserClockOffset);
        _nowLocal = _nowUtc.Add(_browserLocalOffset);
    }

    private async Task LoadQueueAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            UpdateClock();
            var cookingTask = KitchenService.GetCookingItemsAsync();
            var waitingTask = KitchenService.GetWaitingItemsAsync();
            await Task.WhenAll(cookingTask, waitingTask);
            ApplyQueueSnapshot(new KitchenQueueSnapshotDto
            {
                Cooking = cookingTask.Result,
                Waiting = waitingTask.Result
            });
        }
        catch
        {
            errorMessage = "No se pudo cargar la cocina. Reintentá en unos segundos.";
            cookingItems = [];
            waitingItems = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleQueueChanged(KitchenQueueSnapshotDto snapshot)
    {
        await InvokeAsync(() =>
        {
            ApplyQueueSnapshot(snapshot);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private void ApplyQueueSnapshot(KitchenQueueSnapshotDto snapshot)
    {
        UpdateClock();

        var incoming = (snapshot.Cooking ?? []).Concat(snapshot.Waiting ?? []).ToList();
        var incomingIds = incoming.Select(item => item.ItemId).ToHashSet();

        if (_knownItemIds is not null)
        {
            var nowThreshold = _nowUtc.AddSeconds(30);
            var newNowItemIds = incoming
                .Where(item => !_knownItemIds.Contains(item.ItemId)
                    && item.StartTime.HasValue
                    && AsUtc(item.StartTime.Value) <= nowThreshold)
                .Select(item => item.ItemId)
                .ToList();

            if (newNowItemIds.Count > 0)
            {
                var stampedAt = DateTime.UtcNow;
                foreach (var itemId in newNowItemIds)
                    _newItemSince[itemId] = stampedAt;

                if (_lastSoundPlayedAt is null || DateTime.UtcNow - _lastSoundPlayedAt.Value >= SoundThrottle)
                {
                    _lastSoundPlayedAt = DateTime.UtcNow;
                    _ = PlayNewDishSoundAsync();
                }
            }
        }

        _knownItemIds = incomingIds;
        cookingItems = snapshot.Cooking ?? [];
        waitingItems = snapshot.Waiting ?? [];
        ClampCurrentPage();
    }

    private bool IsNew(Guid itemId) => _newItemSince.ContainsKey(itemId);

    private void ExpireNewItemTags()
    {
        if (_newItemSince.Count == 0)
            return;

        var cutoff = DateTime.UtcNow - NewItemTagDuration;
        var expired = _newItemSince.Where(kv => kv.Value < cutoff).Select(kv => kv.Key).ToList();

        foreach (var itemId in expired)
            _newItemSince.Remove(itemId);
    }

    private async Task PlayNewDishSoundAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("fastRestaurantSound.playNewDish");
        }
        catch
        {
        }
    }

    private KitchenItemView ToKitchenItemView(KitchenQueueItemDto item)
    {
        var startAtUtc = item.StartTime.HasValue ? AsUtc(item.StartTime.Value) : DateTime.MaxValue;
        var readyAtUtc = item.FinishTime.HasValue
            ? AsUtc(item.FinishTime.Value)
            : (startAtUtc == DateTime.MaxValue ? DateTime.MaxValue : startAtUtc.AddMinutes(Math.Max(0, item.EstimatedTime)));

        return new KitchenItemView(
            item.ItemId,
            ShortId(item.OrderId),
            item.TableNumber,
            item.ProductName,
            item.Quantity,
            item.Notes,
            item.EstimatedTime,
            startAtUtc,
            readyAtUtc);
    }

    private string TabClass(KitchenTab tab)
        => _activeTab == tab ? "tab-button active" : "tab-button";

    private void SetActiveTab(KitchenTab tab)
    {
        _activeTab = tab;
        _currentPage = 1;
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
            _currentPage--;
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages)
            _currentPage++;
    }

    private string RowClass(KitchenItemView item)
    {
        if (_activeTab == KitchenTab.Upcoming)
            return "ticket-row upcoming-row";

        if (item.ReadyAtUtc == DateTime.MaxValue)
            return "ticket-row now-row";

        var remaining = (item.ReadyAtUtc - _nowUtc).TotalMinutes;
        var urgencyClass = remaining <= 5 ? "urgent-row" : remaining <= 15 ? "warning-row" : "now-row";
        return $"ticket-row {urgencyClass}";
    }

    private string PrimaryTimeLabel(KitchenItemView item)
    {
        var targetTime = _activeTab == KitchenTab.Upcoming ? item.StartAtUtc : item.ReadyAtUtc;

        if (targetTime == DateTime.MaxValue)
            return "-";

        var remaining = (int)Math.Ceiling((targetTime - _nowUtc).TotalMinutes);
        if (remaining < 0)
            return $"+{Math.Abs(remaining)}";

        return remaining.ToString();
    }

    private string SecondaryTimeLabel(KitchenItemView item)
    {
        var targetTime = _activeTab == KitchenTab.Upcoming ? item.StartAtUtc : item.ReadyAtUtc;

        if (targetTime == DateTime.MaxValue)
            return "en espera";

        return targetTime < _nowUtc ? "demora" : "min";
    }

    private string ReadyAtLabel(KitchenItemView item)
        => item.ReadyAtUtc == DateTime.MaxValue ? "-" : ToBrowserLocal(item.ReadyAtUtc).ToString("HH:mm");

    private bool CanConfirm(KitchenItemView item)
        => !isCompleting && item.StartAtUtc <= _nowUtc;

    private string ActionLabel(KitchenItemView item)
    {
        if (item.StartAtUtc > _nowUtc)
            return "Aún no";

        return "Listo";
    }

    private void AskFinishConfirmation(KitchenItemView item)
    {
        if (!CanConfirm(item))
            return;

        _itemToConfirm = item;
    }

    private void CancelFinishConfirmation()
    {
        _itemToConfirm = null;
    }

    private async Task ConfirmFinished()
    {
        if (_itemToConfirm is null)
            return;

        isCompleting = true;
        var completed = await KitchenService.CompleteItemAsync(_itemToConfirm.ItemId);
        _itemToConfirm = null;

        if (!completed)
            errorMessage = "No se pudo marcar el plato como listo. Reintentá.";

        await LoadQueueAsync();
        isCompleting = false;
    }

    private static string ShortId(Guid id)
        => id.ToString("N")[..6];

    private static DateTime AsUtc(DateTime value) => value.Kind switch
    {
        DateTimeKind.Utc => value,
        DateTimeKind.Local => value.ToUniversalTime(),
        _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
    };

    private DateTime ToBrowserLocal(DateTime utc)
        => utc.Add(_browserLocalOffset);

    private void ClampCurrentPage()
    {
        _currentPage = Math.Clamp(_currentPage, 1, TotalPages);
    }

    private enum KitchenTab
    {
        Now,
        Upcoming
    }

    private sealed record KitchenItemView(
        Guid ItemId,
        string OrderNumber,
        int TableNumber,
        string Name,
        int Quantity,
        string? Notes,
        int DurationMinutes,
        DateTime StartAtUtc,
        DateTime ReadyAtUtc)
    {
        public string NoteDisplay => string.IsNullOrWhiteSpace(Notes) ? "-" : Notes;
    }

    public void Dispose()
    {
        _clockTimerCancellation?.Cancel();
        _clockTimerCancellation?.Dispose();
        _clockTimer?.Dispose();
        KitchenRealtime.QueueChanged -= HandleQueueChanged;
        KitchenRealtime.Reconnected -= LoadQueueAsync;
    }
}
