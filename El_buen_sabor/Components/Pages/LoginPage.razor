@page "/"

@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService authService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using El_buen_sabor.Components.Service
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Layout
@layout LoginLayout


<div class="login-page">
    <div class="login-panel">
        <div class="login-band"></div>

        <main class="login-content">
            <img src="/Img/logofast.png" alt="Fast Restaurant" class="login-logo" />

            <div class="login-form">
                <div class="login-field">
                    <label>Usuario</label>
                    <input class="login-input" @bind="username" placeholder="Ingrese su usuario" />
                </div>

                <div class="login-field">
                    <label>Contraseña</label>
                    <input type="password" class="login-input" @bind="password" placeholder="Ingrese su contraseña" />
                </div>

                <button class="login-button" @onclick="LoginUser" disabled="@isSubmitting">
                    @(isSubmitting ? "Ingresando..." : "Iniciar Sesión")
                </button>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="login-error">
                        @Error
                    </div>
                }
            </div>
        </main>

        <footer class="login-footer">Todos los derechos reservados</footer>
    </div>
</div>

@code {
    private string username ="";
    private string password = "";
    private string Error = "";
    private bool isSubmitting = false;

    private async Task LoginUser()
    {
        isSubmitting = true;
        Error = string.Empty;

        try
        {
            var result = await authService.Login(new LoginRequest
                {
                    UserName = username,
                    Password = password
                });

            Console.WriteLine("RESPUESTA RECIBIDA");

            if (result == null)
            {
                Error = "Usuario o contraseña incorrectos";
                return;
            }

            await LocalStorage.SetItemAsync("token", result.Token);
            await LocalStorage.SetItemAsync("refreshToken", result.RefreshToken);

            Navigation.NavigateTo("/DashboardSection");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
