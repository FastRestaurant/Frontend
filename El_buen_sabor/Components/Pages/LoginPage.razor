@page "/"

@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthService authService
@inject AuthSessionService AuthSession
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using El_buen_sabor.Components.Service
@using El_buen_sabor.Components.Models
@using El_buen_sabor.Components.Layout
@layout LoginLayout

<PageTitle>Ingresar - FastRestaurant</PageTitle>

@if (isCheckingSession)
{
    <div class="login-page">
        <div class="login-panel">
            <main class="login-content">
                <img src="/Img/logofast.png" alt="Fast Restaurant" class="login-logo" />
                <div class="login-form">
                    <div class="login-error" role="status">Verificando sesión...</div>
                </div>
            </main>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-panel">
            <div class="login-band"></div>

            <main class="login-content">
                <img src="/Img/logofast.png" alt="Fast Restaurant" class="login-logo" />

                <div class="login-form">
                    <div class="login-field">
                        <label for="login-username">Usuario</label>
                        <input id="login-username" class="login-input" @bind="username" autocomplete="username" placeholder="Ingrese su usuario" />
                    </div>

                    <div class="login-field">
                        <label for="login-password">Contraseña</label>
                        <input id="login-password" type="password" class="login-input" @bind="password" autocomplete="current-password" placeholder="Ingrese su contraseña" />
                    </div>

                    <button type="button" class="login-button" @onclick="LoginUser" disabled="@isSubmitting">
                        @(isSubmitting ? "Ingresando..." : "Iniciar Sesión")
                    </button>

                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <div class="login-error" role="alert">
                            @Error
                        </div>
                    }
                </div>
            </main>

            <footer class="login-footer">Todos los derechos reservados</footer>
        </div>
    </div>
}

@code {
    private string username ="";
    private string password = "";
    private string Error = "";
    private bool isSubmitting = false;
    private bool isCheckingSession;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            if (await AuthSession.IsAuthenticatedAsync())
            {
                var role = await AuthSession.GetRoleAsync();
                Navigation.NavigateTo(AuthSessionService.GetHomePathForRole(role), replace: true);
                return;
            }
        }
        catch
        {
            await AuthSession.ClearSessionAsync();
        }

        isCheckingSession = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoginUser()
    {
        isSubmitting = true;
        Error = string.Empty;

        try
        {
            var result = await authService.Login(new LoginRequest
                {
                    UserName = username,
                    Password = password
                });

            Console.WriteLine("RESPUESTA RECIBIDA");

            if (result == null)
            {
                Error = "Usuario o contraseña incorrectos";
                return;
            }

            await LocalStorage.SetItemAsync("token", result.Token);
            await LocalStorage.SetItemAsync("refreshToken", result.RefreshToken);

            var role = await AuthSession.GetRoleAsync();
            Navigation.NavigateTo(AuthSessionService.GetHomePathForRole(role));
        }
        catch (HttpRequestException netEx)
        {
            Error = "Error de conexión: No se pudo conectar con el servidor de autenticación. Verifique que el servicio esté en ejecución.";
            Console.WriteLine(netEx.ToString());
        }
        catch (Exception ex)
        {
            Error = "Ocurrió un error inesperado al intentar iniciar sesión.";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
