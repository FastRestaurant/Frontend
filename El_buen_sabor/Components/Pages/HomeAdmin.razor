@page "/HomeAdmin"


@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Http

@using El_buen_sabor.Components.Layout
@layout AdminLayout

<section class="content-section">
    <h2>Datos Importantes:</h2>
    <div class="cards-grid">
        <div class="custom-card">Card 1</div>
        <div class="custom-card">Card 2</div>
        <div class="custom-card">Card 3</div>
        <div class="custom-card">Card 4</div>
    </div>
</section>

<section class="content-section">
    <h2>Platos más solicitados en el día de hoy:</h2>
    <div class="cards-grid">
        <div class="custom-card">Plato 1</div>
        <div class="custom-card">Plato 2</div>
        <div class="custom-card">Plato 3</div>
        <div class="custom-card">Plato 4</div>
    </div>
</section>

<section class="content-section">
    <h2>Cuellos de botella:</h2>
    <div class="cards-grid">
        <div class="custom-card">Incidencia 1</div>
        <div class="custom-card">Incidencia 2</div>
        <div class="custom-card">Incidencia 3</div>
        <div class="custom-card">Incidencia 4</div>
    </div>
</section>

<style>
    

    .content-section {
        margin-bottom: 40px;
    }

    .content-section h2 {
        color: white;
        margin-bottom: 20px;
        font-size: 1.5rem;
    }
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .custom-card {
        background-color: white;
        border: 2px solid #0582ca;
        border-radius: 8px;
        padding: 25px;
        min-height: 100px;
        color: #333;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
    }
</style>
